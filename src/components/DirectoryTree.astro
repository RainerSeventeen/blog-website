---
import type { ArticleNode, FolderNode } from "../lib/content-tree";

interface Props {
	nodes: (FolderNode | ArticleNode)[];
}

const { nodes } = Astro.props;

function formatDate(date?: Date): string | undefined {
	if (!date) return undefined;

	return new Intl.DateTimeFormat("zh-CN", {
		year: "numeric",
		month: "short",
		day: "numeric",
	}).format(date);
}

function slugToHref(slug: string): string {
	return `/${slug}/`;
}
---

<ul class="directory-tree">
	{
		nodes.map((node) =>
			node.type === "folder" ? (
				<li class="tree-folder">
					<div class="tree-folder-head">
						<a class="tree-folder-link" href={slugToHref(node.slug)}>
							{node.title}
						</a>
						<div class="tree-folder-meta">
							<span>{node.articleCount} 篇</span>
							{node.lastUpdated && <span>{formatDate(node.lastUpdated)}</span>}
						</div>
					</div>
					{node.description && <p class="tree-folder-desc">{node.description}</p>}
					{node.children.length > 0 && <Astro.self nodes={node.children} />}
				</li>
			) : (
				<li class="tree-article">
					<a class="tree-article-link" href={slugToHref(node.slug)}>
						<span>{node.title}</span>
						{node.pubDate && <time datetime={node.pubDate.toISOString()}>{formatDate(node.pubDate)}</time>}
					</a>
					{node.description && <p class="tree-article-desc">{node.description}</p>}
				</li>
			)
		)
	}
</ul>

<style>
	@layer starlight.components {
		.directory-tree {
			list-style: none;
			margin: 0;
			padding: 0 0 0 1rem;
			border-left: 1px solid var(--sl-color-hairline);
			display: grid;
			gap: 1rem;
		}

		.tree-folder,
		.tree-article {
			display: grid;
			gap: 0.45rem;
		}

		.tree-folder-head {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			justify-content: space-between;
			gap: 0.5rem 1rem;
		}

		.tree-folder-link,
		.tree-article-link {
			color: var(--sl-color-white);
			text-decoration: none;
			font-weight: 600;
			transition:
				color 180ms ease,
				opacity 180ms ease;
		}

		.tree-folder-link:hover,
		.tree-article-link:hover {
			color: var(--sl-color-text-accent);
		}

		.tree-folder-meta,
		.tree-article-link time {
			color: var(--sl-color-gray-3);
			font-size: var(--sl-text-xs);
		}

		.tree-folder-meta {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
		}

		.tree-folder-desc,
		.tree-article-desc {
			margin: 0;
			color: var(--sl-color-gray-3);
			font-size: var(--sl-text-sm);
			line-height: 1.65;
		}

		.tree-article-link {
			display: flex;
			flex-wrap: wrap;
			align-items: baseline;
			justify-content: space-between;
			gap: 0.5rem 1rem;
		}
	}
</style>
