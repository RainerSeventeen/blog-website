---
import { Icon } from "astro-icon/components";
import type { MarkdownHeading } from "astro";

interface Props {
  showBackTop?: boolean;
  showBackBottom?: boolean;
  scrollToTopDistance?: number;
  headings?: MarkdownHeading[];
}

const {
  showBackTop = true,
  showBackBottom = false,
  scrollToTopDistance = 100,
  headings = [],
} = Astro.props;

const tocHeadings = headings.filter((heading) => heading.depth === 2);
---

<div
  id="fabMenu"
  class="pointer-events-none fixed bottom-[5vh] right-[7vw] z-[1000] h-10 w-10 opacity-0 transition-opacity duration-300 lg:bottom-[13.5vh] lg:left-[var(--toc-offset-left)]"
  data-scroll-distance={scrollToTopDistance}
>
  <div id="menuItems" class="pointer-events-none absolute bottom-full left-0 mb-3 flex translate-y-10 flex-col items-center gap-3 opacity-0 transition-all duration-300 ease-out [.is-active_&]:pointer-events-auto [.is-active_&]:translate-y-0 [.is-active_&]:opacity-100">
    {showBackTop && (
      <button id="backTop" title="回到顶部" class="relative flex h-10 w-10 items-center justify-center rounded-full border border-[var(--text-color)]/20 bg-[var(--bg-color)]/20 shadow-none backdrop-blur transition-transform duration-200 hover:bg-[var(--button-hover-color)] active:scale-90">
        <svg class="absolute -left-[1px] -top-[1px] h-[calc(100%+2px)] w-[calc(100%+2px)] -rotate-90 overflow-visible" viewBox="0 0 40 40">
          <circle id="progress-circle" cx="20" cy="20" r="19" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="0 119.4" stroke-linecap="round"></circle>
        </svg>
        <Icon name="fa6-solid:arrow-up" class="relative z-10 text-lg text-[var(--text-color)]" />
      </button>
    )}

    {tocHeadings.length > 0 && (
      <button id="tocTrigger" title="目录" class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--text-color)]/20 bg-[var(--bg-color)]/20 shadow-none backdrop-blur transition-transform duration-200 hover:bg-[var(--button-hover-color)] active:scale-90 lg:hidden">
        <Icon name="fa6-solid:list-ul" class="text-lg text-[var(--text-color)]" />
      </button>
    )}

    {showBackBottom && (
      <button id="backBottom" title="回到底部" class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--text-color)]/20 bg-[var(--bg-color)]/20 shadow-none backdrop-blur transition-transform duration-200 hover:bg-[var(--button-hover-color)] active:scale-90">
        <Icon name="fa6-solid:arrow-down" class="text-lg text-[var(--text-color)]" />
      </button>
    )}
  </div>

  <button id="menuTrigger" title="操作菜单" class="flex h-full w-full items-center justify-center rounded-full border border-[var(--text-color)]/20 bg-[var(--bg-color)]/20 shadow-none backdrop-blur transition-all duration-300 hover:bg-[var(--button-hover-color)] active:scale-95">
    <Icon name="fa6-solid:ellipsis" class="absolute rotate-0 text-lg text-[var(--text-color)] opacity-100 transition-all duration-300 [.is-active_&]:rotate-90 [.is-active_&]:opacity-0" />
    <Icon name="fa6-solid:xmark" class="absolute -rotate-90 text-lg text-[var(--text-color)] opacity-0 transition-all duration-300 [.is-active_&]:rotate-0 [.is-active_&]:opacity-100" />
  </button>

  {tocHeadings.length > 0 && (
    <div id="tocPanel" class="pointer-events-none absolute bottom-25 right-0 z-[1001] flex max-h-[60vh] w-60 scale-50 flex-col rounded-2xl border border-[var(--text-color)]/20 bg-[var(--bg-color)]/95 opacity-0 shadow-2xl backdrop-blur-lg transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)] [.toc-active_&]:pointer-events-auto [.toc-active_&]:scale-100 [.toc-active_&]:translate-x-0 [.toc-active_&]:translate-y-0 [.toc-active_&]:opacity-100 lg:hidden">
      <div class="flex items-center justify-between rounded-t-2xl bg-[var(--button-hover-color)] px-4 py-2.5 text-sm font-medium text-[var(--text-color)]/80">
        <span>目录</span>
        <button id="closeToc" class="text-xs opacity-60 transition-opacity hover:opacity-100">
          关闭
        </button>
      </div>
      <div class="flex-1 overflow-y-auto p-2">
        <ul class="flex flex-col space-y-0.5 text-sm">
          {tocHeadings.map((heading) => (
            <li>
              <a href={`#${heading.slug}`} class="toc-link block line-clamp-2 rounded-lg px-3 py-1 text-[var(--text-color)]/80 leading-[1.35] transition-all duration-200 hover:bg-[var(--text-color)]/10 hover:text-[var(--text-color)]">
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  )}
</div>

<script is:inline>
  function initFabMenu() {
    const container = document.getElementById("fabMenu");
    const trigger = document.getElementById("menuTrigger");
    const backTop = document.getElementById("backTop");
    const backBottom = document.getElementById("backBottom");
    const progressCircle = document.getElementById("progress-circle");
    const tocTrigger = document.getElementById("tocTrigger");
    const closeToc = document.getElementById("closeToc");
    const tocLinks = document.querySelectorAll(".toc-link");

    if (!container || !trigger || container.dataset.bound === "true") {
      return;
    }

    container.dataset.bound = "true";

    const threshold = parseInt(container.dataset.scrollDistance || "100", 10);
    let isTocOpen = false;
    let scrollPosOnTocOpen = 0;

    const handleScroll = () => {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;

      if (scrollTop > threshold) {
        container.classList.remove("opacity-0", "pointer-events-none");
        container.classList.add("opacity-100", "pointer-events-auto");
      } else {
        container.classList.add("opacity-0", "pointer-events-none");
        container.classList.remove("opacity-100", "pointer-events-auto", "is-active", "toc-active");
        isTocOpen = false;
      }

      if (isTocOpen && Math.abs(scrollTop - scrollPosOnTocOpen) > 50) {
        isTocOpen = false;
        container.classList.remove("toc-active");
      }

      if (progressCircle && docHeight > 0) {
        const scrollPercent = Math.min(100, (scrollTop / docHeight) * 100);
        const circumference = 2 * Math.PI * 20;
        const offset = circumference - (scrollPercent / 100) * circumference;
        progressCircle.style.strokeDasharray = `${circumference - offset} ${offset}`;
      }
    };

    trigger.onclick = (event) => {
      event.stopPropagation();
      container.classList.toggle("is-active");
      if (!container.classList.contains("is-active")) {
        isTocOpen = false;
        container.classList.remove("toc-active");
      }
    };

    if (tocTrigger) {
      tocTrigger.onclick = (event) => {
        event.stopPropagation();
        isTocOpen = !isTocOpen;
        container.classList.toggle("toc-active", isTocOpen);
        if (isTocOpen) {
          scrollPosOnTocOpen = window.scrollY || document.documentElement.scrollTop;
        }
      };
    }

    if (closeToc) {
      closeToc.onclick = (event) => {
        event.stopPropagation();
        isTocOpen = false;
        container.classList.remove("toc-active");
      };
    }

    tocLinks.forEach((link) => {
      link.onclick = (event) => {
        event.preventDefault();
        const targetId = link.getAttribute("href")?.substring(1);
        const targetElement = targetId ? document.getElementById(targetId) : null;
        if (!targetElement) {
          return;
        }

        const offset = 60;
        const bodyRect = document.body.getBoundingClientRect().top;
        const elementRect = targetElement.getBoundingClientRect().top;
        const elementPosition = elementRect - bodyRect;
        window.scrollTo({
          top: elementPosition - offset,
          behavior: "smooth",
        });

        isTocOpen = false;
        container.classList.remove("toc-active");
      };
    });

    if (backTop) {
      backTop.onclick = () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
        container.classList.remove("is-active", "toc-active");
        isTocOpen = false;
      };
    }

    if (backBottom) {
      backBottom.onclick = () => {
        window.scrollTo({ top: document.body.scrollHeight, behavior: "smooth" });
        container.classList.remove("is-active", "toc-active");
        isTocOpen = false;
      };
    }

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();
  }

  document.addEventListener("astro:page-load", initFabMenu);
</script>
