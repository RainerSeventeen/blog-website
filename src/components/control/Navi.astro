---
const { page } = Astro.props;

const currentPage = page.currentPage;
const totalPages = page.lastPage;
const showPrevious = currentPage > 1;
const showNext = currentPage < totalPages;

function getVisiblePages(current: number, total: number) {
  const delta = 1;
  const range = [];
  const rangeWithDots = [];
  let last;

  for (let index = 1; index <= total; index++) {
    if (index === 1 || index === total || (index >= current - delta && index <= current + delta)) {
      range.push(index);
    }
  }

  for (const index of range) {
    if (last) {
      if (index - last === 2) {
        rangeWithDots.push(last + 1);
      } else if (index - last !== 1) {
        rangeWithDots.push("...");
      }
    }
    rangeWithDots.push(index);
    last = index;
  }

  return rangeWithDots;
}

function getPageUrl(pageNumber: number) {
  return pageNumber === 1 ? "/" : `/${pageNumber}/`;
}

const visiblePages = getVisiblePages(currentPage, totalPages);
const btnBaseClass = "flex items-center rounded-lg border p-2 transition-all duration-200 md:px-4 md:py-2";
const btnActiveProps = "border-[var(--button-border-color)] text-[var(--text-color)] hover:bg-[var(--button-hover-color)] active:scale-90";
const btnDisabledProps = "pointer-events-none border-[var(--button-border-color)] text-[var(--text-color-70)] opacity-40";
---

<nav data-aos="fade-up" class="mx-auto my-8 flex max-w-[var(--page-width)] flex-row items-center justify-between gap-1 text-sm">
  <a href={showPrevious ? getPageUrl(currentPage - 1) : "#"} class={`${btnBaseClass} ${showPrevious ? btnActiveProps : btnDisabledProps}`} aria-label="Previous Page">
    <svg class="h-5 w-5 md:mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
    <span class="hidden md:inline">上一页</span>
  </a>

  <div class="no-scrollbar flex flex-nowrap items-center gap-1 overflow-x-auto md:gap-2">
    {visiblePages.map((pageNumber) => {
      if (pageNumber === "...") {
        return (
          <span class="flex h-8 w-8 items-center justify-center text-[var(--text-color-70)] md:h-10 md:w-10">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <circle cx="5" cy="12" r="1.5" />
              <circle cx="12" cy="12" r="1.5" />
              <circle cx="19" cy="12" r="1.5" />
            </svg>
          </span>
        );
      }

      const isCurrent = pageNumber === currentPage;
      return (
        <a
          href={getPageUrl(pageNumber as number)}
          class={`flex h-8 w-8 items-center justify-center rounded-lg border transition-all duration-200 md:h-10 md:w-10 ${
            isCurrent
              ? "pointer-events-none border-[var(--button-border-color)] font-bold text-[var(--text-color)]"
              : "border-transparent text-[var(--text-color-70)] hover:border-[var(--button-border-color)] hover:text-[var(--text-color)] active:scale-90 active:bg-[var(--button-hover-color)]"
          }`}
        >
          {pageNumber}
        </a>
      );
    })}
  </div>

  <a href={showNext ? getPageUrl(currentPage + 1) : "#"} class={`${btnBaseClass} ${showNext ? btnActiveProps : btnDisabledProps}`} aria-label="Next Page">
    <span class="hidden md:inline">下一页</span>
    <svg class="h-5 w-5 md:ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</nav>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }

  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
