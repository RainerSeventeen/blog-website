---
import type { BreadcrumbItem } from "@utils/content-utils";

interface Props {
  items: BreadcrumbItem[];
  align?: "left" | "center";
}

const { items, align = "left" } = Astro.props;
---

{items.length > 0 && (
  <nav aria-label="文章路径导航" class:list={["flex", align === "center" ? "justify-center" : "justify-start"]}>
    <ol
      class:list={[
        "flex flex-wrap items-center gap-x-3 gap-y-1 text-[0.8rem] font-medium tracking-[0.08em] text-[var(--text-color-70)] sm:text-sm",
        align === "center" ? "justify-center" : "justify-start",
      ]}
    >
      {items.map((item, index) => (
        <li class="flex items-center gap-3">
          {index > 0 && <span aria-hidden="true" class="text-[var(--button-border-color)]">/</span>}
          {item.href ? (
            <a
              href={item.href}
              class="rounded-sm transition-colors duration-200 hover:text-[var(--text-color)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--link-color)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg-color)] motion-reduce:transition-none"
            >
              {item.label}
            </a>
          ) : (
            <span aria-current={index === items.length - 1 ? "page" : undefined} class="text-[var(--text-color)]">
              {item.label}
            </span>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}
