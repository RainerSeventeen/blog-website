---
import { Icon } from "astro-icon/components";

interface Props {
  prev: any;
  next: any;
}

const { prev, next } = Astro.props;

function getPostUrl(id: string) {
  return `/blog/${id}/`;
}
---

<nav data-aos="fade-up" class="mt-8 border-t border-[var(--button-border-color)] pt-4">
  <div class="flex flex-row items-stretch gap-2 sm:gap-4">
    <div class="min-w-0 flex-1">
      {prev && (
        <a href={getPostUrl(prev.id)} class="group flex h-full flex-col gap-1 rounded-lg p-3 no-underline transition-all hover:bg-[var(--button-hover-color)] active:bg-[var(--button-hover-color)] sm:p-4">
          <div class="flex items-center gap-1.5 text-[var(--text-color-70)]">
            <Icon name="fa6-solid:arrow-left" class="h-4 w-4" />
            <span class="text-sm transition-colors group-hover:text-[var(--text-color)]">上一篇</span>
          </div>
          <span class="text-lg font-bold text-[var(--text-color)] transition-colors group-hover:text-[var(--link-color)] group-active:text-[var(--link-color)]">
            {prev.data.title}
          </span>
        </a>
      )}
    </div>
    <div class="min-w-0 flex-1">
      {next && (
        <a href={getPostUrl(next.id)} class="group flex h-full flex-col items-end gap-1 rounded-lg p-3 text-right no-underline transition-all hover:bg-[var(--button-hover-color)] active:bg-[var(--button-hover-color)] sm:p-4">
          <div class="flex items-center gap-1.5 text-[var(--text-color-70)]">
            <span class="text-sm transition-colors group-hover:text-[var(--text-color)]">下一篇</span>
            <Icon name="fa6-solid:arrow-right" class="h-4 w-4" />
          </div>
          <span class="text-lg font-bold text-[var(--text-color)] transition-colors group-hover:text-[var(--link-color)] group-active:text-[var(--link-color)]">
            {next.data.title}
          </span>
        </a>
      )}
    </div>
  </div>
</nav>
