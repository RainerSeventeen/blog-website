---
import { buildContentTree, type Ancestor } from "../lib/content-tree";

// PAGE_TITLE_ID = '_top' (Starlight internal constant)
const PAGE_TITLE_ID = "_top";

const { starlightRoute } = Astro.locals;
const currentId = starlightRoute.entry.id; // e.g. "deep-learning/training/lora-paper"

const BREADCRUMB_LABELS: Record<string, string> = {
	"deep-learning": "深度学习",
	"code-algorithm": "代码算法",
	tools: "工具使用",
	foundations: "基础",
	papers: "论文",
	multimodal: "多模态",
	transformers: "Transformer",
	training: "训练",
	interview: "面试",
	answer: "题解",
	"01-engineering": "工程",
	"02-ml-dl": "机器学习与深度学习",
	"03-transformer-llm": "Transformer 与 LLM",
	"04-training": "训练",
	"05-models": "模型",
	"06-rag-agent": "RAG 与 Agent",
	python: "Python",
};

let ancestors: Ancestor[] = [];

try {
	const tree = await buildContentTree();
	const article = tree.articlesByPath.get(currentId);
	if (article) {
		ancestors = article.ancestors;
	}
} catch {
	// Graceful degradation: if tree fails, skip breadcrumbs
}

function slugToHref(slug: string): string {
	return `/${slug}/`;
}

function getLabel(slug: string, title: string): string {
	const exactMatch = BREADCRUMB_LABELS[slug];
	if (exactMatch) return exactMatch;

	const lastSegment = slug.split("/").at(-1) ?? slug;
	return BREADCRUMB_LABELS[lastSegment] ?? title;
}
---

{
	ancestors.length > 0 && (
		<nav aria-label="breadcrumb" class="sl-breadcrumbs">
			<ol>
				{ancestors.map((ancestor, i) => (
					<li>
						{i > 0 && <span aria-hidden="true" class="sep">›</span>}
						<a class="crumb-link" href={slugToHref(ancestor.slug)}>
							{getLabel(ancestor.slug, ancestor.title)}
						</a>
					</li>
				))}
				<li>
					<span aria-hidden="true" class="sep">›</span>
					<span aria-current="page">{starlightRoute.entry.data.title}</span>
				</li>
			</ol>
		</nav>
	)
}

<h1 id={PAGE_TITLE_ID}>{starlightRoute.entry.data.title}</h1>

<style>
	@layer starlight.core {
		h1 {
			margin-top: 1rem;
			font-size: var(--sl-text-h1);
			line-height: var(--sl-line-height-headings);
			font-weight: 600;
			color: var(--sl-color-white);
		}
	}

	.sl-breadcrumbs {
		margin-bottom: 0.25rem;
	}

	.sl-breadcrumbs ol {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.25rem;
		list-style: none;
		padding: 0;
		margin: 0;
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
	}

	.sl-breadcrumbs li {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.sl-breadcrumbs .crumb-link {
		color: var(--sl-color-gray-3);
		text-decoration: none;
		transition: color 160ms ease;
	}

	.sl-breadcrumbs .crumb-link:hover {
		color: var(--sl-color-white);
	}

	.sl-breadcrumbs [aria-current="page"] {
		color: var(--sl-color-gray-2);
	}

	.sep {
		color: var(--sl-color-gray-4);
	}
</style>
