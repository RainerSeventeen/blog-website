---
import { Icon } from "astro-icon/components";
import BlogNavi from "@components/control/BlogNavi.astro";
import FabMenu from "@components/control/FabMenu.astro";
import TOC from "@components/TOC.svelte";
import ImageModule from "@components/misc/ImageModule.astro";
import Markdown from "@components/misc/Markdown.astro";
import type { ArticlePageModel } from "@utils/content-utils";
import { formatFullDate } from "@utils/time";
import { blogCoverUrl } from "@utils/url-utils";

interface Props {
  model: ArticlePageModel;
}

const { model } = Astro.props;
const ArticleContent = model.Content;
const articleImage = blogCoverUrl(model.image, model.entry.id);
---

<>
  <div class="mx-auto mb-12 mt-24 w-full max-w-[var(--page-width)] py-8 md:mt-0">
    <div class="mb-18 pt-10 text-center">
      <h1 class="mb-2 text-3xl font-bold text-[var(--text-color)]">{model.entry.data.title}</h1>
      <p class="mt-6 flex flex-wrap items-center justify-center font-bold text-[var(--text-color-70)]">
        <Icon name="fa6-solid:calendar-days" class="mr-2" />
        <span>{formatFullDate(model.entry.data.pubDate, "zh-CN")}</span>
      </p>
      <div class="flex justify-center">
        <div class="mt-2 flex flex-wrap items-center justify-center gap-2 text-sm text-[var(--text-color-70)]">
          <p class="mr-2 flex items-center whitespace-nowrap">
            <Icon name="fa6-solid:pen-nib" class="mr-1" />
            <span class="px-1 py-1">{model.reading.words || 0} 字</span>
          </p>
          <p class="mr-2 flex items-center whitespace-nowrap">
            <Icon name="fa6-solid:clock" class="mr-1" />
            <span class="px-1 py-1">{model.reading.minutes || 0} 分钟</span>
          </p>
          <p class="mr-2 flex items-center whitespace-nowrap">
            <Icon name="fa6-solid:hashtag" class="mr-1" />
            <span>{model.entry.data.category}</span>
          </p>
        </div>
      </div>
    </div>

    {articleImage && (
      <div class="cover overflow-hidden">
        <ImageModule src={articleImage} class="h-full w-full object-cover" />
      </div>
    )}

    {model.entry.data.draft && (
      <div class="my-8 flex items-start gap-3 rounded-lg border border-[var(--danger-border-color)] bg-[var(--danger-bg-color)] p-4 text-sm text-[var(--danger-text-color)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 opacity-80">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
          <line x1="12" y1="9" x2="12" y2="13" />
          <line x1="12" y1="17" x2="12.01" y2="17" />
        </svg>
        <div>
          <p class="leading-relaxed"><span class="font-semibold">草稿文章。</span> 当前内容仍在整理中。</p>
        </div>
      </div>
    )}

    <Markdown class="mb-6 mt-10">
      <ArticleContent />
    </Markdown>

    <BlogNavi prev={model.prev} next={model.next} />
  </div>

  <TOC
    headings={model.headings}
    topicEntries={model.topicEntries}
    currentEntryId={model.currentEntryId}
    parentFolder={model.parentFolderLink}
    client:load
  />
  <FabMenu headings={model.headings} showBackBottom={true} />
</>
