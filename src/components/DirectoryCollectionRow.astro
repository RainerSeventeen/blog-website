---
import type { DirectoryCollectionItem } from "@utils/content-utils";

interface Props {
  item: DirectoryCollectionItem;
}

const { item } = Astro.props;
const kindLabel = item.kind === "folder" ? "目录" : "文章";
---

<a
  href={item.href}
  class="group flex items-start gap-4 rounded p-2 transition-all duration-200 hover:bg-[var(--button-hover-color)] focus:outline-none focus-visible:bg-[var(--button-hover-color)] motion-reduce:transition-none"
>
  <span class="min-w-[56px] pt-1 text-base font-medium text-[var(--text-color-70)] md:min-w-[72px] md:text-[1.05rem]">
    {kindLabel}
  </span>

  <span class="min-w-0 flex-1">
    <span class="flex flex-wrap items-center gap-x-3 gap-y-1">
      <span class="text-lg transition-all duration-200 group-hover:pl-2 group-hover:font-bold group-hover:text-[var(--link-color)] group-focus-visible:pl-2 group-focus-visible:font-bold group-focus-visible:text-[var(--link-color)] motion-reduce:transition-none">
        {item.title}
      </span>

      {item.kind === "article" && item.badge && (
        <span class="text-sm font-mono text-[var(--text-color-70)]">
          {item.badge}
        </span>
      )}
    </span>

    {item.meta && (
      <span class="mt-1 block text-sm leading-6 text-[var(--text-color-70)]">{item.meta}</span>
    )}

    {item.description && (
      <span class="directory-preview mt-1 block text-sm leading-6 text-[var(--text-color-70)]">
        {item.description}
      </span>
    )}
  </span>
</a>

<style>
  .directory-preview {
    display: -webkit-box;
    overflow: hidden;
    text-overflow: ellipsis;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }
</style>
