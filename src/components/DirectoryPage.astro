---
import { getDirectoryPageData } from "../lib/content-tree";
import DirectoryTree from "./DirectoryTree.astro";

const { starlightRoute } = Astro.locals;
const directory = await getDirectoryPageData(starlightRoute.entry.id);

function formatDate(date?: Date): string | undefined {
	if (!date) return undefined;

	return new Intl.DateTimeFormat("zh-CN", {
		year: "numeric",
		month: "short",
		day: "numeric",
	}).format(date);
}

function formatCount(value: number): string {
	return new Intl.NumberFormat("zh-CN").format(value);
}

const summary =
	(starlightRoute.entry.data.directorySummary as string | undefined) ??
	starlightRoute.entry.data.description ??
	directory?.folder.description ??
	"查看当前目录下的全部内容与层级结构。";

const hasSupplement = Astro.slots.has("default");
---

{
	directory ? (
		<div class="directory-page">
			<p class="directory-summary">{summary}</p>

			<ul class="directory-meta" aria-label="目录概览">
				<li class="directory-meta-item">
					<span class="directory-meta-label">子目录</span>
					<strong class="directory-meta-value">{formatCount(directory.childFolderCount)}</strong>
				</li>
				<li class="directory-meta-item">
					<span class="directory-meta-label">文章总数</span>
					<strong class="directory-meta-value">{formatCount(directory.folder.articleCount)}</strong>
				</li>
				{directory.lastUpdated && (
					<li class="directory-meta-item">
						<span class="directory-meta-label">最后整理</span>
						<strong class="directory-meta-value">{formatDate(directory.lastUpdated)}</strong>
					</li>
				)}
			</ul>

				{
					directory.folder.children.length > 0 && (
						<section class="directory-section" aria-labelledby="directory-structure">
							<div class="section-heading">
								<h2 id="directory-structure">内容结构</h2>
							</div>
							<DirectoryTree
								nodes={directory.folder.children}
								rootLabel={`${directory.folder.slug.split("/").filter(Boolean).pop()}/`}
							/>
						</section>
					)
				}

			{
				hasSupplement && (
					<section class="directory-section directory-note" aria-labelledby="directory-note">
						<div class="section-heading">
							<h2 id="directory-note">补充说明</h2>
						</div>
						<div class="directory-note-body">
							<slot />
						</div>
					</section>
				)
			}
		</div>
	) : (
		<p class="directory-empty">当前目录暂无可展示的结构信息。</p>
	)
}

<style>
	@layer starlight.components {
		.directory-page {
			display: grid;
			gap: 2rem;
		}

		.directory-summary,
		.directory-empty {
			margin: 0;
			color: var(--sl-color-gray-2);
			font-size: var(--sl-text-body);
			line-height: var(--sl-line-height);
		}

		.directory-meta {
			list-style: none;
			display: flex;
			flex-wrap: wrap;
			align-items: flex-start;
			gap: 0.9rem clamp(2rem, 4vw, 4rem);
			margin: 0;
			padding-left: 0;
			padding: 1.1rem 0 0;
			border-top: 1px solid var(--sl-color-hairline);
		}

		.directory-meta-item {
			display: grid;
			align-content: start;
			gap: 0.35rem;
			margin: 0;
			min-width: 0;
		}

		.directory-meta-label {
			font-size: var(--sl-text-xs);
			color: var(--sl-color-gray-3);
			text-transform: uppercase;
			letter-spacing: 0.08em;
			line-height: 1.4;
			white-space: nowrap;
		}

		.directory-meta-value {
			color: var(--sl-color-white);
			font-size: clamp(1.4rem, 1.2rem + 0.4vw, 1.9rem);
			font-weight: 700;
			line-height: 1.15;
			white-space: nowrap;
		}

		.directory-section {
			display: grid;
			gap: 1.15rem;
		}

		.section-heading {
			display: grid;
			gap: 0.25rem;
			padding-top: 0.15rem;
			border-top: 1px solid var(--sl-color-hairline);
		}

		.section-heading h2 {
			margin: 0;
			padding-top: 1rem;
			font-size: clamp(1.35rem, 1.1rem + 0.7vw, 1.9rem);
			letter-spacing: -0.03em;
		}

		.directory-note-body {
			padding: 1rem 0 0;
			border-top: 1px solid var(--sl-color-hairline);
		}

		.directory-note :global(*:first-child) {
			margin-top: 0;
		}

		.directory-note :global(*:last-child) {
			margin-bottom: 0;
		}

		@media (max-width: 50rem) {
			.directory-meta {
				flex-direction: column;
				align-items: flex-start;
				gap: 0.9rem;
			}
		}
	}
</style>
