---
import LandingLayout from "@/layouts/LandingLayout.astro";
import ThemeIcon from "@components/control/ThemeIcon.astro";
import { Icon } from "astro-icon/components";
import { profileConfig, siteConfig } from "@/config";

const { crossSiteLinks } = siteConfig;
---

<LandingLayout>
  <div class="relative min-h-screen flex items-center justify-center text-[var(--text-color)]">
    <div class="absolute top-6 right-6">
      <ThemeIcon class="flex h-10 w-10 items-center justify-center rounded-lg border border-[var(--button-border-color)] transition-all duration-300 hover:bg-[var(--button-hover-color)] active:scale-90" />
    </div>

    <div class="flex flex-col items-center text-center w-full max-w-md px-6 py-16">
      <img
        src={profileConfig.avatar}
        alt={profileConfig.name}
        class="w-24 h-24 rounded-full object-cover mb-6 border-2 border-[var(--button-border-color)]"
      />

      <h1 class="landing-logo text-4xl font-bold mb-2">{profileConfig.name}</h1>

      <p class="text-lg text-[var(--text-color-70)] mb-2">{profileConfig.motto}</p>

      <p class="text-base text-[var(--text-color-70)] mb-10 leading-relaxed whitespace-nowrap">
        {profileConfig.description}
      </p>

      <div class="grid grid-cols-2 gap-4 w-full mb-8">
        <a
          href={crossSiteLinks.noteSite}
          class="group flex flex-col items-center gap-2 rounded-xl border border-[var(--button-border-color)] p-6 transition-all duration-300 hover:border-[var(--link-color)] hover:shadow-[0_8px_20px_var(--shadow-color)]"
        >
          <Icon name="fa6-solid:book-open" class="h-6 w-6 text-[var(--link-color)]" />
          <span class="font-bold text-lg">Notes</span>
          <span class="text-sm text-[var(--text-color-70)]">知识笔记</span>
        </a>

        <a
          href={crossSiteLinks.projectSite}
          class="group flex flex-col items-center gap-2 rounded-xl border border-[var(--button-border-color)] p-6 transition-all duration-300 hover:border-[var(--link-color)] hover:shadow-[0_8px_20px_var(--shadow-color)]"
          title={crossSiteLinks.projectSite === "#" ? "即将上线" : undefined}
        >
          <Icon name="fa6-solid:code-branch" class="h-6 w-6 text-[var(--link-color)]" />
          <span class="font-bold text-lg">Projects</span>
          <span class="text-sm text-[var(--text-color-70)]">项目展示</span>
        </a>
      </div>

      <div class="flex gap-3">
        {
          profileConfig.links.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              class="flex h-10 w-10 items-center justify-center rounded-lg border border-[var(--button-border-color)] transition-all duration-300 hover:bg-[var(--button-hover-color)] active:scale-90"
            >
              <Icon name={link.icon} class="h-4 w-4" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</LandingLayout>

<style>
  .landing-logo {
    font-family: "EB Garamond", cursive;
    letter-spacing: 1px;
  }
</style>
