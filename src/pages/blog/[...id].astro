---
import { render } from "astro:content";
import { Icon } from "astro-icon/components";
import FabMenu from "@components/control/FabMenu.astro";
import BlogNavi from "@components/control/BlogNavi.astro";
import TOC from "@components/TOC.svelte";
import Markdown from "@components/misc/Markdown.astro";
import ImageModule from "@components/misc/ImageModule.astro";
import MainPageLayout from "@layouts/MainPageLayout.astro";
import { siteConfig } from "@/config";
import { getBlogEntries } from "@utils/content-utils";
import { formatFullDate } from "@utils/time";
import { blogCoverUrl } from "@utils/url-utils";

export async function getStaticPaths() {
  const blogEntries = await getBlogEntries();

  return blogEntries.map((entry, index) => ({
    params: { id: entry.id },
    props: {
      entry,
      next: index > 0 ? blogEntries[index - 1] : null,
      prev: index < blogEntries.length - 1 ? blogEntries[index + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(entry);
const pageTitle = `${entry.data.title} - ${siteConfig.title}`;
const image = blogCoverUrl(entry.data.image, entry.id);
---

<MainPageLayout title={pageTitle} description={entry.data.description}>
  <div class="mx-auto mb-12 mt-18 w-full max-w-[var(--page-width)] py-8 md:mt-0">
    <div class="mb-18 text-center">
      <h1 class="mb-2 pt-10 text-3xl font-bold text-[var(--text-color)]">{entry.data.title}</h1>
      <p class="mt-6 flex flex-wrap items-center justify-center font-bold text-[var(--text-color-70)]">
        <Icon name="fa6-solid:calendar-days" class="mr-2" />
        <span>{formatFullDate(entry.data.pubDate, "zh-CN")}</span>
      </p>
      <div class="flex justify-center">
        <div class="mt-2 flex flex-wrap items-center justify-center gap-2 text-sm text-[var(--text-color-70)]">
          <p class="mr-2 flex items-center whitespace-nowrap">
            <Icon name="fa6-solid:pen-nib" class="mr-1" />
            <span class="px-1 py-1">{remarkPluginFrontmatter.words || 0} 字</span>
          </p>
          <p class="mr-2 flex items-center whitespace-nowrap">
            <Icon name="fa6-solid:clock" class="mr-1" />
            <span class="px-1 py-1">{remarkPluginFrontmatter.minutes || 0} 分钟</span>
          </p>
          <p class="mr-2 flex items-center whitespace-nowrap">
            <Icon name="fa6-solid:hashtag" class="mr-1" />
            <span>{entry.data.category}</span>
          </p>
        </div>
      </div>
    </div>

    {image && (
      <div class="cover overflow-hidden">
        <ImageModule src={image} class="h-full w-full object-cover" />
      </div>
    )}

    {entry.data.draft && (
      <div class="my-8 flex items-start gap-3 rounded-lg border border-[var(--danger-border-color)] bg-[var(--danger-bg-color)] p-4 text-sm text-[var(--danger-text-color)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 opacity-80">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
          <line x1="12" y1="9" x2="12" y2="13" />
          <line x1="12" y1="17" x2="12.01" y2="17" />
        </svg>
        <div>
          <p class="leading-relaxed"><span class="font-semibold">草稿文章。</span> 当前内容仍在整理中。</p>
        </div>
      </div>
    )}

    <Markdown class="mb-6 mt-10">
      <Content />
    </Markdown>

    <BlogNavi prev={prev} next={next} />
  </div>

  {siteConfig.toc.enable && <TOC headings={headings} client:load />}
  <FabMenu headings={headings} showBackBottom={true} />
</MainPageLayout>
