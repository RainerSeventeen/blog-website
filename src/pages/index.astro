---
import { profileConfig, siteConfig } from "@/config";
import FabMenu from "@components/control/FabMenu.astro";
import ImageModule from "@components/misc/ImageModule.astro";
import MainPageLayout from "@layouts/MainPageLayout.astro";
import { formatFullDate } from "@utils/time";
import {
  getArticlePath,
  getBlogEntries,
  getBlogPath,
  getContentTree,
  isIndexEntry,
} from "@utils/content-utils";
import { Icon } from "astro-icon/components";

type HomeTopic = {
  title: string;
  description: string;
  count: number;
  href: string;
};

const fallbackDescriptions: Record<string, string> = {
  "deep-learning-playbook":
    "系统整理深度学习基础、论文精读、面试主线与专项问答，方便长期复习。",
  "tools-manual": "沉淀开发环境、容器、服务器和 AI 工作流相关的可复用实践。",
  "code-basics": "汇总语言、框架 API 与高频编码细节，适合查阅和快速回看。",
  "project-notes": "记录项目背景、设计思路、实现方案与阶段性总结。",
};

const tree = await getContentTree();
const rootTopics: HomeTopic[] = tree.root.folders.map((folder) => ({
  title: folder.title,
  description:
    folder.indexEntry?.data.description?.trim() ||
    fallbackDescriptions[folder.path] ||
    "按主题整理的内容入口。",
  count: folder.articleCountRecursive,
  href: getBlogPath(folder.path),
}));

const topicTitleByPath = new Map(
  tree.root.folders.map((folder) => [folder.path, folder.title]),
);
const latestEntries = (await getBlogEntries()).filter((entry) => !isIndexEntry(entry)).slice(0, 6);
const pageTitle = `${siteConfig.title} - ${siteConfig.subTitle}`;
const authorLinks = profileConfig.links.filter((link) => link.url !== "/rss.xml");
const aboutPageHref = "/about/";
const introParagraphs = [
  "这个站点不是资讯流，而是一个持续整理中的 AI / 深度学习知识库。内容会围绕基础原理、论文理解、工程实践和项目复盘逐步沉淀。",
  "首页只保留最重要的入口：先说明这里写什么，再给出专题分类和最近更新，尽量让第一次访问时就能快速建立上下文。",
];
---

<MainPageLayout title={pageTitle} description={profileConfig.description}>
  <div class="mx-auto mt-24 w-full max-w-[var(--page-width)] px-5 py-8 md:mt-0 md:px-0">
    <section class="home-section home-intro" aria-labelledby="home-title">
      <p class="home-kicker">Knowledge Base</p>
      <h1 id="home-title" class="home-title">{siteConfig.title}</h1>
      <p class="home-subtitle">{siteConfig.subTitle}</p>

      <div class="home-copy">
        {introParagraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
        <p>{profileConfig.description}</p>
      </div>

    </section>

    <section class="home-section author-section" aria-labelledby="home-author-title">
      <h2 id="home-author-title" class="sr-only">作者栏</h2>

      <div class="author-card">
        <a href={aboutPageHref} class="author-avatar-wrap" aria-label={`查看 ${profileConfig.name} 的关于页面`}>
          <ImageModule
            src={profileConfig.avatar}
            alt={`${profileConfig.name} 头像`}
            class="author-avatar"
          />
        </a>

        <div class="author-body">
          <div class="author-identity">
            <a href={aboutPageHref} class="author-name-link">
              <p class="author-name">{profileConfig.name}</p>
            </a>
          </div>
          <p class="author-motto">{profileConfig.motto}</p>

          <div class="author-links" aria-label="作者外部链接">
            {authorLinks.map((link) => (
              <a
                href={link.url}
                class="author-link"
                aria-label={link.label}
                title={link.label}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon name={link.icon} class="author-link-icon" />
                <span class="author-link-label">{link.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="home-section" aria-labelledby="home-latest-title">
      <div class="section-heading">
        <h2 id="home-latest-title">最新更新</h2>
        <p>按发布时间倒序展示，优先放最近整理过的文章，便于快速浏览新增内容。</p>
      </div>

      <div class="stack-list">
        {latestEntries.slice(0, 5).map((entry) => (
          <a href={getBlogPath(getArticlePath(entry))} class="stack-row latest-row">
            <div class="stack-copy">
              <div class="latest-meta">
                <span>{topicTitleByPath.get(entry.data.section) || entry.data.section}</span>
                <time datetime={entry.data.pubDate.toISOString()}>
                  {formatFullDate(entry.data.pubDate, "zh-CN")}
                </time>
              </div>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description || "继续阅读这篇内容。"}</p>
            </div>
            <Icon name="fa6-solid:angle-right" class="stack-icon" aria-hidden="true" />
          </a>
        ))}
      </div>
    </section>
  </div>

  <FabMenu showBackBottom={true} />
</MainPageLayout>

<style>
  .home-section + .home-section {
    margin-top: 4rem;
  }

  .home-intro {
    padding-top: 0.75rem;
  }

  .home-kicker {
    margin: 0;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-color-70);
  }

  .home-title {
    margin: 1rem 0 0;
    font-size: clamp(2.5rem, 7vw, 3.5rem);
    line-height: 1.08;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text-color);
    text-wrap: balance;
  }

  .home-subtitle {
    margin: 1rem 0 0;
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--text-color-70);
  }

  .home-copy,
  .section-heading p,
  .stack-copy p,
  .overview-item dt,
  .latest-meta {
    color: var(--text-color-70);
  }

  .home-copy {
    margin-top: 1.75rem;
    display: grid;
    gap: 1rem;
    font-size: 1rem;
    line-height: 1.95;
  }

  .home-copy p,
  .section-heading p,
  .stack-copy p,
  .overview-item dt,
  .latest-meta {
    margin: 0;
  }

  .stack-row {
    transition:
      color 220ms ease,
      background-color 220ms ease,
      border-color 220ms ease,
      transform 220ms ease;
  }

  .section-heading {
    display: grid;
    gap: 0.6rem;
  }

  .section-heading h2 {
    margin: 0;
    font-size: 1.55rem;
    line-height: 1.25;
    color: var(--text-color);
  }

  .stack-list {
    margin-top: 1.5rem;
    border-top: 1px solid var(--button-border-color);
  }

  .stack-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    margin: 0 -0.75rem;
    padding: 1.25rem 0.75rem;
    border-bottom: 1px solid var(--button-border-color);
    border-radius: 1rem;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }

  .stack-row:hover,
  .stack-row:focus-visible {
    background: color-mix(in srgb, var(--button-hover-color) 82%, transparent);
    outline: none;
    transform: translateY(-1px);
  }

  .stack-copy {
    min-width: 0;
    display: grid;
    gap: 0.55rem;
  }

  .stack-topline,
  .latest-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .stack-copy h3 {
    margin: 0;
    font-size: 1.12rem;
    line-height: 1.45;
    color: var(--text-color);
    transition: color 220ms ease, transform 220ms ease;
  }

  .stack-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--text-color-70);
    transition: color 220ms ease, transform 220ms ease;
  }

  .latest-meta,
  .stack-copy p {
    transition: color 220ms ease;
  }

  .latest-row:hover .latest-meta,
  .latest-row:focus-visible .latest-meta,
  .latest-row:hover .stack-copy p,
  .latest-row:focus-visible .stack-copy p {
    color: var(--text-color);
  }

  .latest-row:hover .stack-copy h3,
  .latest-row:focus-visible .stack-copy h3 {
    color: var(--link-color);
    transform: translateX(0.2rem);
  }

  .latest-row:hover .stack-icon,
  .latest-row:focus-visible .stack-icon {
    color: var(--link-color);
    transform: translateX(0.25rem);
  }

  .author-section {
    border-top: 1px solid var(--button-border-color);
    padding-top: 2rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .author-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1.25rem;
    align-items: center;
  }

  .author-avatar-wrap {
    display: block;
    width: 5rem;
    height: 5rem;
    flex-shrink: 0;
    border-radius: 999rem;
    text-decoration: none;
    transition: transform 220ms ease;
  }

  .author-avatar-wrap:hover,
  .author-avatar-wrap:focus-visible {
    transform: translateY(-2px);
    outline: none;
  }

  .author-avatar {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 999rem;
    object-fit: cover;
    border: 2px solid color-mix(in srgb, var(--link-color) 30%, transparent);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--link-color) 8%, transparent),
      0 8px 24px color-mix(in srgb, var(--shadow-color) 25%, transparent);
    transition:
      border-color 220ms ease,
      box-shadow 220ms ease;
  }

  .author-avatar-wrap:hover .author-avatar,
  .author-avatar-wrap:focus-visible .author-avatar {
    border-color: color-mix(in srgb, var(--link-color) 55%, transparent);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--link-color) 12%, transparent),
      0 12px 28px color-mix(in srgb, var(--shadow-color) 28%, transparent);
  }

  .author-body {
    min-width: 0;
    display: grid;
    gap: 0.5rem;
  }

  .author-identity {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .author-kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--link-color);
  }

  .author-name {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-color);
  }

  .author-name-link {
    color: inherit;
    text-decoration: none;
    transition: color 220ms ease;
  }

  .author-name-link:hover,
  .author-name-link:focus-visible {
    color: var(--link-color);
    outline: none;
  }

  .author-motto {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--text-color-70);
  }

  .author-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .author-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem 0.3rem 0.6rem;
    border: 1px solid var(--button-border-color);
    border-radius: 999rem;
    font-size: 0.8rem;
    color: var(--text-color-70);
    text-decoration: none;
    cursor: pointer;
    transition:
      color 220ms ease,
      background-color 220ms ease,
      border-color 220ms ease,
      transform 220ms ease;
  }

  .author-link:hover,
  .author-link:focus-visible {
    background: var(--button-hover-color);
    color: var(--link-color);
    border-color: color-mix(in srgb, var(--link-color) 40%, transparent);
    transform: translateY(-1px);
    outline: none;
  }

  .author-link-icon {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
  }

  .author-link-label {
    line-height: 1;
  }

  @media (min-width: 776px) {
    .home-intro {
      padding-top: 2.5rem;
    }
  }

  @media (max-width: 640px) {
    .home-section + .home-section {
      margin-top: 3rem;
    }

    .author-card {
      gap: 1rem;
    }

    .author-avatar-wrap {
      width: 4.25rem;
      height: 4.25rem;
    }

    .latest-meta {
      display: grid;
      justify-content: initial;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stack-row,
    .author-link,
    .author-avatar-wrap,
    .author-avatar,
    .author-name-link {
      transition: none;
    }
  }
</style>
