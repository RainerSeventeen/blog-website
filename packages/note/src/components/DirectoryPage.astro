---
import { Image } from "astro:assets";
import noteArtwork from "../../../home/src/images/destinations/note.svg";
import { getDirectoryPageData } from "../lib/content-tree";
import DirectoryTree from "./DirectoryTree.astro";

const { starlightRoute } = Astro.locals;
const directory = await getDirectoryPageData(starlightRoute.entry.id);
const isNoteRoot = directory?.folder.slug === "";
const NOTE_ROOT_TABLE_ID = "note-top-level-categories";

function formatDate(date?: Date): string | undefined {
	if (!date) return undefined;

	return new Intl.DateTimeFormat("zh-CN", {
		year: "numeric",
		month: "short",
		day: "numeric",
	}).format(date);
}

function formatCount(value: number): string {
	return new Intl.NumberFormat("zh-CN").format(value);
}

function slugToHref(slug: string): string {
	return slug ? `/${slug}/` : "/";
}

function getSectionSummary(): string {
	if (directory?.folder.generatedDirectoryPage) return "暂无简介";

	return (
		directory?.folder.directorySummary ??
		directory?.folder.description ??
		"查看当前目录下的全部内容与层级结构。"
	);
}

function getChildFolderSummary(
	description?: string,
	directorySummary?: string
): string {
	return description ?? directorySummary ?? "查看该分区下的全部内容。";
}

const summary = getSectionSummary();

const hasSupplement = Astro.slots.has("default");
const treeRootLabel = directory
	? `${directory.folder.shortLabel ?? directory.folder.title ?? "note"}/`
	: "note/";
---

{
	directory ? (
		<div class="directory-page">

			<p class="directory-summary">{summary}</p>
			{isNoteRoot && (
				<div class="note-root-artwork">
					<Image
						src={noteArtwork}
						alt="Note 站插画"
						class="note-root-artwork-img"
					/>
				</div>
			)}

			<ul class="directory-meta" aria-label="目录概览">
				<li class="directory-meta-item">
					<span class="directory-meta-label">子目录</span>
					<strong class="directory-meta-value">{formatCount(directory.childFolderCount)}</strong>
				</li>
				<li class="directory-meta-item">
					<span class="directory-meta-label">文章总数</span>
					<strong class="directory-meta-value">{formatCount(directory.folder.articleCount)}</strong>
				</li>
				{directory.lastUpdated && (
					<li class="directory-meta-item">
						<span class="directory-meta-label">最后更新</span>
						<strong class="directory-meta-value">{formatDate(directory.lastUpdated)}</strong>
					</li>
				)}
			</ul>

			{
				isNoteRoot ? (
					<>
						{directory.recentArticles.length > 0 && (
							<section class="directory-section" aria-labelledby="note-recent-updates">
								<div class="section-heading">
									<h2 id="note-recent-updates">最近更新</h2>
								</div>

								<ul class="recent-articles" role="list">
									{directory.recentArticles.map((article) => (
										<li class="recent-article">
											<a href={slugToHref(article.slug)} class="recent-link">
												<span class="recent-copy">
													<strong class="recent-title">{article.title}</strong>
													{article.description && (
														<span class="recent-description">{article.description}</span>
													)}
												</span>
												{(article.updated ?? article.published) && (
													<time
														class="recent-date"
														datetime={(article.updated ?? article.published)!.toISOString()}
													>
														{formatDate(article.updated ?? article.published)}
													</time>
												)}
											</a>
										</li>
									))}
								</ul>
							</section>
						)}

						<section class="directory-section" aria-labelledby={NOTE_ROOT_TABLE_ID}>
							<div class="section-heading">
								<h2 id={NOTE_ROOT_TABLE_ID}>顶级分类</h2>
							</div>

							<div class="directory-table-wrap">
								<table class="directory-table">
									<thead>
										<tr>
											<th scope="col">分类</th>
											<th scope="col">子目录</th>
											<th scope="col">文章总数</th>
											<th scope="col">最后更新</th>
										</tr>
									</thead>
									<tbody>
										{directory.childFolders.map((folder) => {
											const childFolderCount = folder.children.filter(
												(child) => child.type === "folder"
											).length;

											return (
												<tr>
													<th scope="row">
														<a href={slugToHref(folder.slug)} class="section-link">
															{folder.title}
														</a>
														<div class="table-summary">
															{getChildFolderSummary(
																folder.description,
																folder.directorySummary
															)}
														</div>
													</th>
													<td>{formatCount(childFolderCount)}</td>
													<td>{formatCount(folder.articleCount)}</td>
													<td>{formatDate(folder.lastUpdated) ?? " -"}</td>
												</tr>
											);
										})}
									</tbody>
								</table>
							</div>
						</section>
					</>
				) : (
					directory.folder.children.length > 0 && (
						<section class="directory-section" aria-labelledby="directory-structure">
							<div class="section-heading">
								<h2 id="directory-structure">内容结构</h2>
							</div>
							<DirectoryTree
								nodes={directory.folder.children}
								rootLabel={treeRootLabel}
							/>
						</section>
					)
				)
			}

			{
				hasSupplement && (
					<section class="directory-section directory-note" aria-labelledby="directory-note">
						<div class="section-heading">
							<h2 id="directory-note">补充说明</h2>
						</div>
						<div class="directory-note-body">
							<slot />
						</div>
					</section>
				)
			}
		</div>
	) : (
		<p class="directory-empty">当前目录暂无可展示的结构信息。</p>
	)
}

<style>
	@layer starlight.components {
		.directory-page {
			display: grid;
			gap: 2rem;
		}

		.note-root-artwork {
			display: flex;
			align-items: center;
			justify-content: center;
			overflow: hidden;
			border-radius: 0.75rem;
			border: 1px solid var(--sl-color-hairline);
			background: color-mix(in srgb, var(--sl-color-white) 3%, transparent);
			padding: 0.75rem;
			max-height: 220px;
		}

		.note-root-artwork-img {
			height: 100%;
			max-height: 200px;
			width: auto;
			object-fit: contain;
		}

		.directory-summary,
		.directory-empty,
		.section-summary {
			margin: 0;
			color: var(--sl-color-gray-2);
			font-size: var(--sl-text-body);
			line-height: var(--sl-line-height);
		}

		.directory-meta {
			list-style: none;
			display: flex;
			flex-wrap: wrap;
			align-items: flex-start;
			gap: 0.9rem clamp(2rem, 4vw, 4rem);
			margin: 0;
			padding-left: 0;
			padding: 1.1rem 0 0;
			border-top: 1px solid var(--sl-color-hairline);
		}

		.directory-meta-item {
			display: grid;
			align-content: start;
			gap: 0.35rem;
			margin: 0;
			min-width: 0;
		}

		.directory-meta-label {
			font-size: var(--sl-text-xs);
			color: var(--sl-color-gray-3);
			text-transform: uppercase;
			letter-spacing: 0.08em;
			line-height: 1.4;
			white-space: nowrap;
		}

		.directory-meta-value {
			color: var(--sl-color-white);
			font-size: clamp(1.4rem, 1.2rem + 0.4vw, 1.9rem);
			font-weight: 700;
			line-height: 1.15;
			white-space: nowrap;
		}

		.directory-section {
			display: grid;
			gap: 1.15rem;
		}

		.section-heading {
			display: grid;
			gap: 0.25rem;
			padding-top: 0.15rem;
			border-top: 1px solid var(--sl-color-hairline);
		}

		.section-heading h2 {
			margin: 0;
			padding-top: 1rem;
			font-size: clamp(1.35rem, 1.1rem + 0.7vw, 1.9rem);
			letter-spacing: -0.03em;
		}

		.section-link {
			color: var(--sl-color-white);
			text-decoration: none;
			transition: color 180ms ease;
		}

		.section-link:hover,
		.section-link:focus-visible {
			color: var(--sl-color-accent-high);
		}

		.recent-link:hover,
		.recent-link:focus-visible {
			background: color-mix(in srgb, var(--sl-color-white) 5%, transparent);
		}

		.recent-link:hover .recent-title,
		.recent-link:focus-visible .recent-title {
			color: var(--sl-color-accent-high);
		}

		.section-meta-copy {
			margin: 0;
			color: var(--sl-color-gray-3);
			font-size: var(--sl-text-xs);
			line-height: 1.6;
		}

		.recent-articles {
			list-style: none;
			display: grid;
			margin: 0;
			padding: 0.25rem 0;
			border-top: 1px solid var(--sl-color-hairline);
		}

		.recent-article {
			margin: 0;
			border-bottom: 1px solid var(--sl-color-hairline);
		}

		.recent-article:last-child {
			border-bottom: none;
		}

		.recent-link {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 1rem;
			padding: 0.75rem 0.6rem;
			margin: 0 -0.6rem;
			color: inherit;
			text-decoration: none;
			border-radius: 0.4rem;
			transition: background 160ms ease;
		}

		.recent-copy {
			display: grid;
			gap: 0.2rem;
			min-width: 0;
		}

		.recent-title {
			color: var(--sl-color-white);
			font-size: var(--sl-text-body);
			font-weight: 600;
			line-height: 1.4;
		}

		.recent-description {
			color: var(--sl-color-gray-3);
			font-size: var(--sl-text-sm);
			line-height: 1.5;
		}

		.recent-date {
			flex-shrink: 0;
			color: var(--sl-color-gray-3);
			font-size: var(--sl-text-sm);
			line-height: 1.4;
			white-space: nowrap;
		}

		.directory-table-wrap {
			overflow-x: auto;
			border-top: 1px solid var(--sl-color-hairline);
		}

		.directory-table {
			width: 100%;
			border-collapse: collapse;
			min-width: 36rem;
		}

		.directory-table th,
		.directory-table td {
			padding: 1rem 0.75rem;
			border-bottom: 1px solid var(--sl-color-hairline);
			text-align: left;
			vertical-align: middle;
		}

		/* 去掉左右边缘 padding，与最近更新列表横向对齐 */
		.directory-table th:first-child,
		.directory-table td:first-child {
			padding-left: 0;
		}

		.directory-table th:last-child,
		.directory-table td:last-child {
			padding-right: 0;
		}

		.directory-table thead th {
			padding-top: 1.1rem;
			color: var(--sl-color-gray-3);
			font-size: var(--sl-text-sm);
			font-weight: 600;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			white-space: nowrap;
		}

		/* 分类列撑满剩余宽度，数字列收窄至内容 */
		.directory-table thead th:first-child,
		.directory-table tbody th:first-child {
			width: 100%;
		}


		.directory-table tbody th {
			font-size: clamp(1.05rem, 1rem + 0.2vw, 1.2rem);
			font-weight: 700;
		}

		.directory-table tbody td {
			color: var(--sl-color-white);
			font-size: var(--sl-text-body);
			vertical-align: middle;
			white-space: nowrap;
		}

		.directory-table thead th:nth-child(2),
		.directory-table thead th:nth-child(3),
		.directory-table thead th:nth-child(4) {
			text-align: center;
		}

		.directory-table tbody td:nth-child(2),
		.directory-table tbody td:nth-child(3),
		.directory-table tbody td:nth-child(4) {
			text-align: center;
			white-space: nowrap;
		}

		/* 行 hover：整行底部淡色填充 */
		.directory-table tbody tr {
			transition: background 160ms ease;
		}

		.directory-table tbody tr:hover {
			background: color-mix(in srgb, var(--sl-color-white) 4%, transparent);
		}

		.directory-table tbody tr:hover .section-link {
			color: var(--sl-color-accent-high);
		}

		.table-summary {
			margin-top: 0.35rem;
			color: var(--sl-color-gray-2);
			font-size: var(--sl-text-sm);
			font-weight: 400;
			line-height: 1.55;
		}

		.table-meta-copy {
			margin-top: 0.25rem;
			color: var(--sl-color-gray-3);
			font-size: var(--sl-text-xs);
			font-weight: 400;
			line-height: 1.5;
		}

		.directory-note-body {
			padding: 1rem 0 0;
			border-top: 1px solid var(--sl-color-hairline);
		}

		.directory-note :global(*:first-child) {
			margin-top: 0;
		}

		.directory-note :global(*:last-child) {
			margin-bottom: 0;
		}

		@media (max-width: 50rem) {
			.directory-meta {
				flex-direction: column;
				align-items: flex-start;
				gap: 0.9rem;
			}

			.recent-link {
				flex-direction: column;
				align-items: flex-start;
			}

		}
	}
</style>
