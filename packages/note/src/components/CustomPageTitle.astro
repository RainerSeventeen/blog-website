---
import { Icon } from "@astrojs/starlight/components";
import { buildContentTree, normalizeDirectorySlug, type Ancestor } from "../lib/content-tree";
import {
	inferRouteNavigationContext,
	isNoteHomeRouteId,
	NOTE_DOMAIN_ROOT,
} from "../lib/site-navigation";

// PAGE_TITLE_ID = '_top' (Starlight internal constant)
const PAGE_TITLE_ID = "_top";

const { starlightRoute } = Astro.locals;
const currentId = starlightRoute.entry.id; // e.g. "deep-learning/training/lora-paper"
const routeContext = inferRouteNavigationContext(currentId);
const isNoteHome = routeContext.domain === "note" && isNoteHomeRouteId(currentId);
const showNoteRootCrumb = routeContext.domain === "note" && !isNoteHome;

let ancestors: Ancestor[] = [];
let pageTitle = String(starlightRoute.entry.data.title ?? "");
const published = starlightRoute.entry.data.published as Date | undefined;
const updated = starlightRoute.entry.data.updated as Date | undefined;

try {
	const tree = await buildContentTree();
	const article = tree.articlesByPath.get(currentId);
	if (article) {
		ancestors = article.ancestors;
		pageTitle = article.title;
	} else {
		const folder = tree.foldersByPath.get(normalizeDirectorySlug(currentId));
		if (folder) {
			ancestors = folder.ancestors;
			pageTitle = folder.title;
		}
	}
} catch {
	// Graceful degradation: if tree fails, skip breadcrumbs
}

function slugToHref(slug: string): string {
	return `/${slug}/`;
}

function getDateParts(date?: Date): { year: string; month: string; day: string } | undefined {
	if (!date) return undefined;
	const parts = new Intl.DateTimeFormat("zh-CN", {
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
		timeZone: "Asia/Shanghai",
	})
		.formatToParts(date)
		.reduce<Record<string, string>>((acc, part) => {
			acc[part.type] = part.value;
			return acc;
		}, {});

	return {
		year: parts.year,
		month: parts.month,
		day: parts.day,
	};
}

const breadcrumbItems = [
	...(showNoteRootCrumb ? [NOTE_DOMAIN_ROOT] : []),
	...ancestors.map((ancestor) => ({
		title: ancestor.title,
		href: slugToHref(ancestor.slug),
	})),
];

const publishedParts = getDateParts(published);
const updatedParts = getDateParts(updated);
const publishedLabel = publishedParts
	? `${publishedParts.year}-${publishedParts.month}-${publishedParts.day}`
	: undefined;
const updatedLabel = updatedParts
	? `${updatedParts.year}-${updatedParts.month}-${updatedParts.day}`
	: undefined;
---

{
	(isNoteHome || breadcrumbItems.length > 0) && (
		<nav aria-label="breadcrumb" class="sl-breadcrumbs">
			<ol>
				{
					isNoteHome ? (
						<li>
							<span aria-current="page">{NOTE_DOMAIN_ROOT.title}</span>
						</li>
					) : (
						<>
							{breadcrumbItems.map((item, i) => (
								<li>
									{i > 0 && <span aria-hidden="true" class="sep">›</span>}
									<a class="crumb-link" href={item.href}>
										{item.title}
									</a>
								</li>
							))}
							<li>
								<span aria-hidden="true" class="sep">›</span>
								<span aria-current="page">{pageTitle}</span>
							</li>
						</>
					)
				}
			</ol>
		</nav>
	)
}

<h1 id={PAGE_TITLE_ID}>{pageTitle}</h1>

{
	(publishedLabel || updatedLabel) && (
		<p class="article-dates">
			{publishedLabel && (
				<span class="article-date-item" aria-label={`发布日期: ${publishedLabel}`}>
					<Icon name="document" class="article-date-icon" size="0.875rem" />
					<time datetime={published?.toISOString()}>{publishedLabel}</time>
				</span>
			)}
			{updatedLabel && (
				<span class="article-date-item" aria-label={`最后更新: ${updatedLabel}`}>
					<Icon name="pencil" class="article-date-icon" size="0.875rem" />
					<time datetime={updated?.toISOString()}>{updatedLabel}</time>
				</span>
			)}
		</p>
	)
}

<style>
	@layer starlight.core {
		h1 {
			margin-top: 1rem;
			font-size: var(--sl-text-h1);
			line-height: var(--sl-line-height-headings);
			font-weight: 600;
			color: var(--sl-color-white);
		}
	}

	.article-dates {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		row-gap: 0.25rem;
		margin: 0.5rem 0 0;
		font-size: var(--sl-text-xs);
		line-height: 1.5;
		color: var(--sl-color-gray-3);
	}

	.article-date-item {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		line-height: 1;
	}

	.article-date-item + .article-date-item {
		margin-left: 1.25rem;
	}

	.article-date-item :global(.article-date-icon) {
		display: block;
		flex: 0 0 auto;
		color: currentColor;
		opacity: 0.82;
	}

	.article-dates time {
		color: inherit;
		line-height: 1;
	}

	.sl-breadcrumbs {
		margin-bottom: 0.25rem;
	}

	.sl-breadcrumbs ol {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.25rem;
		list-style: none;
		padding: 0;
		margin: 0;
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
	}

	.sl-breadcrumbs li {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.sl-breadcrumbs .crumb-link {
		color: var(--sl-color-gray-3);
		text-decoration: none;
		transition: color 160ms ease;
	}

	.sl-breadcrumbs .crumb-link:hover {
		color: var(--sl-color-white);
	}

	.sl-breadcrumbs [aria-current="page"] {
		color: var(--sl-color-gray-2);
	}

	.sep {
		color: var(--sl-color-gray-4);
	}
</style>
