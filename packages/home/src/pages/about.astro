---
import MainSiteLayout from "../layouts/MainSiteLayout.astro";
import { aboutPage, profile } from "../lib/main-site-config";

const iconPathByName = {
  email:
    "M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z",
  github:
    "M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12",
  rss:
    "M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20 4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z",
} as const;
---

<MainSiteLayout
  title="关于 | RainerSeventeen"
  description="关于 Rainer 的背景、关注方向和做事方式"
>
  <main>
    <section class="mx-auto mt-24 w-full max-w-4xl px-4 py-16 xl:px-0">
      <div class="max-w-3xl">
        <h1 class="home-heading-1 font-bold text-balance dark:text-gray-100">
          {aboutPage.heroTitle}
        </h1>
        <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
          {aboutPage.heroDescription}
        </p>
      </div>
    </section>

    <section class="mx-auto w-full max-w-4xl px-4 xl:px-0">
      <div class="grid gap-6 rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-slate-800/80 md:grid-cols-[auto_minmax(0,1fr)] md:gap-8 md:p-8">
        <img
          src={profile.avatar}
          alt={`${profile.name} 的头像`}
          width="112"
          height="112"
          loading="lazy"
          class="h-28 w-28 rounded-full object-cover"
        />
        <div class="min-w-0">
          <h2 class="home-heading-2 font-semibold text-balance dark:text-gray-100">
            {profile.name}
          </h2>
          <p class="mt-2 text-sm text-indigo-700 dark:text-indigo-400">
            {profile.motto}
          </p>
          <p class="mt-5 max-w-2xl leading-8 text-gray-600 dark:text-gray-300">
            {aboutPage.teaser}
          </p>
        </div>
        <div class="border-t border-gray-100 dark:border-gray-700/80 md:col-span-2"></div>
        <div class="flex flex-wrap justify-start gap-3 md:col-span-2" aria-label="个人链接">
          {
            profile.links.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith("mailto") || link.href.startsWith("/")
                  ? undefined
                  : "_blank"}
                rel={link.href.startsWith("mailto") || link.href.startsWith("/")
                  ? undefined
                  : "noopener noreferrer"}
                class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-gray-200 px-4 py-2 text-sm text-gray-600 transition-colors duration-200 hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500/30 dark:border-gray-600 dark:text-gray-300 dark:hover:border-indigo-400/60 dark:hover:bg-indigo-500/10 dark:hover:text-indigo-200"
              >
                <svg
                  class="h-4 w-4 shrink-0"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path d={iconPathByName[link.icon]}></path>
                </svg>
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-4xl px-4 py-16 xl:px-0">
      <div class="mb-10 h-px w-16 bg-gray-300 dark:bg-gray-600"></div>
      <div class="home-prose prose prose-zinc max-w-none prose-headings:scroll-mt-24 prose-headings:font-semibold prose-p:leading-8 prose-li:leading-8 prose-strong:text-zinc-900 dark:prose-invert">
        {
          aboutPage.summary.map((paragraph) => (
            <p>{paragraph}</p>
          ))
        }
        {
          aboutPage.markdownSections.map((section) => (
            <section>
              <h2>{section.title}</h2>
              {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              {section.bullets && (
                <ul>
                  {section.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              )}
            </section>
          ))
        }
      </div>
    </section>
  </main>
</MainSiteLayout>
