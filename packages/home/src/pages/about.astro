---
import MainSiteLayout from "../layouts/MainSiteLayout.astro";
import { aboutPage, profile } from "../lib/main-site-config";
import { getSteamProfile } from "../lib/steam";

const [authorSection, ...otherSections] = aboutPage.markdownSections;
const steamCard = otherSections.flatMap((section) => section.cards ?? []).find((card) => card.icon === "steam");
const steamProfile = steamCard ? await getSteamProfile(steamCard.href) : null;

const iconPathByName = {
  email:
    "M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z",
  github:
    "M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12",
  rss:
    "M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20 4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z",
} as const;

function isInternalLink(href: string) {
  return href.startsWith("mailto:") || href.startsWith("/");
}

function getSteamId64(href: string) {
  return href.match(/profiles\/(\d+)/)?.[1] ?? "";
}
---

<MainSiteLayout
  title="关于 | RainerSeventeen"
  description="关于 Rainer 的背景、关注方向和做事方式"
>
  <main>
    <section class="mx-auto mt-24 w-full max-w-4xl px-4 py-16 xl:px-0">
      <div class="max-w-3xl">
        <h1 class="home-heading-1 font-bold text-balance dark:text-gray-100">
          {aboutPage.heroTitle}
        </h1>
      </div>
      <figure class="about-hero-quote mt-10 w-full">
        <svg
          class="about-hero-quote-mark about-hero-quote-mark-start"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M6.5 10c-.223 0-.437.034-.65.065.069-.232.14-.468.254-.68.114-.308.292-.575.469-.844.148-.291.409-.488.601-.737.201-.242.475-.403.692-.604.213-.21.492-.315.714-.463.232-.133.434-.28.65-.35l.539-.222.474-.197-.485-1.938-.597.144c-.191.048-.424.104-.689.171-.271.05-.56.187-.882.312-.318.142-.686.238-1.028.466-.344.218-.741.4-1.091.692-.339.301-.748.562-1.05.945-.33.358-.656.734-.909 1.162-.293.408-.492.856-.702 1.299-.19.443-.343.896-.468 1.336-.237.882-.343 1.72-.384 2.437-.034.718-.014 1.315.028 1.747.015.204.043.402.063.539l.025.168.026-.006A4.5 4.5 0 1 0 6.5 10m11 0c-.223 0-.437.034-.65.065.069-.232.14-.468.254-.68.114-.308.292-.575.469-.844.148-.291.409-.488.601-.737.201-.242.475-.403.692-.604.213-.21.492-.315.714-.463.232-.133.434-.28.65-.35l.539-.222.474-.197-.485-1.938-.597.144c-.191.048-.424.104-.689.171-.271.05-.56.187-.882.312-.317.143-.686.238-1.028.467-.344.218-.741.4-1.091.692-.339.301-.748.562-1.05.944-.33.358-.656.734-.909 1.162-.293.408-.492.856-.702 1.299-.19.443-.343.896-.468 1.336-.237.882-.343 1.72-.384 2.437-.034.718-.014 1.315.028 1.747.015.204.043.402.063.539l.025.168.026-.006A4.5 4.5 0 1 0 17.5 10" />
        </svg>

        <blockquote class="about-hero-quote-body">
          <p class="home-motto font-bold">{aboutPage.heroDescription}</p>
        </blockquote>

        <figcaption class="about-hero-quote-source">
          <span aria-hidden="true">—</span> Ed Sheeran, <span>“One Life”</span>
        </figcaption>

        <svg
          class="about-hero-quote-mark about-hero-quote-mark-end"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="m21.95 8.721-.025-.168-.026.006A4.5 4.5 0 1 0 17.5 14c.223 0 .437-.034.65-.065-.069.232-.14.468-.254.68-.114.308-.292.575-.469.844-.148.291-.409.488-.601.737-.201.242-.475.403-.692.604-.213.21-.492.315-.714.463-.232.133-.434.28-.65.35l-.539.222-.474.197.484 1.939.597-.144c.191-.048.424-.104.689-.171.271-.05.56-.187.882-.312.317-.143.686-.238 1.028-.467.344-.218.741-.4 1.091-.692.339-.301.748-.562 1.05-.944.33-.358.656-.734.909-1.162.293-.408.492-.856.702-1.299.19-.443.343-.896.468-1.336.237-.882.343-1.72.384-2.437.034-.718.014-1.315-.028-1.747a7 7 0 0 0-.063-.539m-11 0-.025-.168-.026.006A4.5 4.5 0 1 0 6.5 14c.223 0 .437-.034.65-.065-.069.232-.14.468-.254.68-.114.308-.292.575-.469.844-.148.291-.409.488-.601.737-.201.242-.475.403-.692.604-.213.21-.492.315-.714.463-.232.133-.434.28-.65.35l-.539.222c-.301.123-.473.195-.473.195l.484 1.939.597-.144c.191-.048.424-.104.689-.171.271-.05.56-.187.882-.312.317-.143.686-.238 1.028-.467.344-.218.741-.4 1.091-.692.339-.301.748-.562 1.05-.944.33-.358.656-.734.909-1.162.293-.408.492-.856.702-1.299.19-.443.343-.896.468-1.336.237-.882.343-1.72.384-2.437.034-.718.014-1.315-.028-1.747a8 8 0 0 0-.064-.537" />
        </svg>
      </figure>
    </section>

    <section class="mx-auto w-full max-w-4xl px-4 pb-16 pt-8 xl:px-0">
      <div class="mb-8 h-px w-16 bg-gray-300 dark:bg-gray-600"></div>
      <div class="home-prose prose prose-zinc max-w-none prose-headings:scroll-mt-24 prose-headings:font-semibold prose-p:leading-8 prose-li:leading-8 prose-strong:text-zinc-900 dark:prose-invert">
        {aboutPage.introParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        <section>
          <h2>关于作者</h2>
          <div class="not-prose mt-6 grid gap-4 rounded-[1.5rem] border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-slate-800/80 md:grid-cols-[auto_minmax(0,1fr)] md:items-center md:gap-6 md:p-6">
            <img
              src={profile.avatar}
              alt={`${profile.name} 的头像`}
              width="112"
              height="112"
              loading="lazy"
              class="h-24 w-24 rounded-full object-cover md:h-28 md:w-28"
            />
            <div class="min-w-0">
              <h3 class="text-xl font-semibold text-balance text-zinc-900 dark:text-gray-100">
                {profile.name}
              </h3>
              <p class="mt-3 max-w-2xl text-sm leading-7 text-gray-600 dark:text-gray-300">
                {aboutPage.teaser}
              </p>
              <div class="mt-4 flex flex-wrap justify-start gap-2.5" aria-label="个人链接">
                {
                  profile.links.map((link) => (
                    <a
                      href={link.href}
                      target={isInternalLink(link.href) ? undefined : "_blank"}
                      rel={isInternalLink(link.href) ? undefined : "noopener noreferrer"}
                      class="inline-flex cursor-pointer items-center gap-1.5 rounded-full border border-gray-200 px-3 py-1.5 text-xs text-gray-600 transition-colors duration-200 hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500/30 dark:border-gray-600 dark:text-gray-300 dark:hover:border-indigo-400/60 dark:hover:bg-indigo-500/10 dark:hover:text-indigo-200"
                    >
                      <svg
                        class="h-3.5 w-3.5 shrink-0"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg"
                        aria-hidden="true"
                      >
                        <path d={iconPathByName[link.icon]}></path>
                      </svg>
                      {link.label}
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
          {authorSection.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          {authorSection.bullets && (
            <ul>
              {authorSection.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          )}
        </section>
        {
          otherSections.map((section) => (
            <section>
              <h2>{section.title}</h2>
              {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              {section.bullets && (
                <ul>
                  {section.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              )}
              {section.cards && section.cards.length > 0 && (
                <div class="not-prose mt-6 grid gap-4">
                  {section.cards.map((card) => (
                    <a
                      href={card.href}
                      target={card.external ? "_blank" : undefined}
                      rel={card.external ? "noopener noreferrer" : undefined}
                      class="about-link-card group flex h-full cursor-pointer flex-col rounded-lg border border-gray-300 bg-white p-3.5 text-inherit shadow-sm transition-all duration-300 hover:border-indigo-500 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 dark:border-gray-700 dark:bg-slate-900/80 dark:hover:border-indigo-400 dark:hover:shadow-[0_8px_20px_rgba(15,23,42,0.35)]"
                    >
                      <div class="flex items-start justify-between gap-3">
                        <div class="flex min-w-0 flex-1 items-center">
                          <div class="flex min-w-0 items-center gap-2">
                            {card.icon === "steam" && steamProfile?.avatar ? (
                              <img
                                src={steamProfile.avatar}
                                alt={`${steamProfile.displayName} 的 Steam 头像`}
                                loading="lazy"
                                class="h-6 w-6 rounded-full border border-gray-200 bg-gray-100 object-cover dark:border-gray-700 dark:bg-slate-800"
                              />
                            ) : (
                              <div class="about-link-card-avatar-fallback flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-gray-200 bg-gray-100 text-slate-950 dark:border-gray-700 dark:bg-slate-800 dark:text-gray-200">
                                <svg
                                  viewBox="0 0 24 24"
                                  class="h-3.5 w-3.5"
                                  fill="currentColor"
                                  xmlns="http://www.w3.org/2000/svg"
                                  aria-hidden="true"
                                >
                                  <path d="M12 0a12 12 0 1 0 10.83 17.17l-5.21-2.15a3.26 3.26 0 0 1-6.17-1.28l-3.73-1.54v.05a4.44 4.44 0 1 0 2.09 3.77l3.44 1.42a3.28 3.28 0 0 1 4.45-1.69 3.27 3.27 0 0 1 1.46 4.33A12 12 0 0 0 12 0Zm0 20.63a2.38 2.38 0 1 1 2.38-2.38A2.38 2.38 0 0 1 12 20.63Zm5.1-8.05a3.22 3.22 0 1 1 3.22-3.22 3.22 3.22 0 0 1-3.22 3.22Z"></path>
                                </svg>
                              </div>
                            )}

                            <span class="truncate text-sm font-semibold text-gray-900 dark:text-gray-100">
                              {steamProfile?.displayName ?? card.title}
                            </span>
                          </div>
                          <span class="mx-1.5 text-sm text-gray-400 dark:text-gray-500">/</span>
                          <span class="truncate text-sm font-semibold text-indigo-600 transition-colors duration-200 group-hover:text-indigo-700 dark:text-indigo-400 dark:group-hover:text-indigo-300">
                            {steamProfile?.steamId64 || getSteamId64(card.href)}
                          </span>
                        </div>

                        <div class="shrink-0 text-slate-950 transition-colors duration-200 dark:text-gray-300">
                          {card.icon === "steam" && (
                            <img
                              src="https://store.fastly.steamstatic.com/public/shared/images/header/logo_steam.svg?t=962016"
                              alt="Steam"
                              loading="lazy"
                              class="h-6 w-auto"
                            />
                          )}
                        </div>
                      </div>

                      <p class="mt-2 line-clamp-2 text-sm leading-6 text-gray-500 dark:text-gray-400">
                        {card.description}
                      </p>
                    </a>
                  ))}
                </div>
              )}
            </section>
          ))
        }
      </div>
    </section>
  </main>
</MainSiteLayout>

<style>
  .about-hero-quote {
    position: relative;
    padding: 1rem 3rem;
    color: rgb(75 85 99);
  }

  .about-hero-quote-body {
    margin: 0;
  }

  .about-hero-quote-body p {
    margin: 0;
    line-height: 1.3;
    text-align: center;
    text-wrap: balance;
    color: #432dd7;
  }

  .about-hero-quote-source {
    margin-top: 1rem;
    width: 100%;
    text-align: right;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    color: rgb(156 163 175);
  }

  .about-hero-quote-source span {
    font-style: italic;
    letter-spacing: 0.02em;
  }

  .about-hero-quote-mark {
    position: absolute;
    height: 1.75rem;
    width: 1.75rem;
    color: rgb(156 163 175);
  }

  .about-hero-quote-mark-start {
    top: 0;
    left: 0;
  }

  .about-hero-quote-mark-end {
    right: 0;
    bottom: 0;
  }

  :global(.dark) .about-hero-quote-source,
  :global(.dark) .about-hero-quote-mark {
    color: rgb(107 114 128);
  }

  .about-link-card-avatar-fallback svg {
    overflow: visible;
  }

  @media (max-width: 640px) {
    .about-hero-quote {
      padding-inline: 2.25rem;
    }

    .about-hero-quote-mark {
      height: 1.35rem;
      width: 1.35rem;
    }
  }
</style>
