---
import { Image } from 'astro:assets'
import {
  aboutPage,
  profile,
  destinations,
  featuredRepos,
} from '../lib/main-site-config'
import { initRepoCache, getRepoCached } from '../lib/github'
import { getRecentNotes } from '../lib/recent-notes'
import mindMapImage from '../images/mind-map.svg'
import codeReviewImage from '../images/code-review.svg'
import dotsTriangle from '../images/dots-triangle.svg'

const recentNotes = await getRecentNotes()

await initRepoCache(featuredRepos)
const repos = featuredRepos.map((repo) => ({
  ...getRepoCached(repo.owner, repo.name),
  href: `https://github.com/${repo.owner}/${repo.name}`,
  description: repo.description,
}))

function formatDate(dateString: string) {
  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).format(new Date(dateString))
}

function formatRepoCount(count: number) {
  return new Intl.NumberFormat('en-US', {
    notation: count >= 1000 ? 'compact' : 'standard',
    maximumFractionDigits: 1,
  }).format(count)
}

function getGitHubAvatar(owner: string) {
  return `https://github.com/${owner}.png?size=48`
}

const emailLink = profile.links.find((link) => link.icon === 'email')
const contactEmail = emailLink?.href.replace('mailto:', '') ?? ''
const [contactEmailLocal = contactEmail, contactEmailDomain = ''] = contactEmail.split('@')
const contactEmailIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" xmlns="http://www.w3.org/2000/svg"><path d="M3.75 6.75h16.5v10.5H3.75z"/><path d="m4.5 7.5 7.5 5.25L19.5 7.5"/></svg>`

---

<main>
  <!-- Hero -->
  <section class="hero mx-auto w-full max-w-4xl py-16 mt-24 px-4 xl:px-0">
    <div class="text-center font-bold sm:text-left">
      <div class="home-heading-1 text-balance dark:text-gray-100">
        {profile.name}
      </div>
      <div class="home-motto mt-2 text-indigo-700 dark:text-indigo-500 sm:whitespace-nowrap">
        {profile.motto}
      </div>
    </div>
  </section>
  <!-- end hero -->

  <!-- Intro -->
  <section class="mx-auto w-full max-w-4xl px-4 xl:px-0">
    <div class="max-w-3xl space-y-4 text-lg leading-8 text-gray-700 dark:text-gray-100">
      <p class="flex flex-wrap items-center gap-x-3 gap-y-2">
        <span>欢迎来到</span>
        <span class="intro-brand inline-flex items-center gap-2 text-slate-900 dark:text-white">
          <svg
            viewBox="0 0 1024 1024"
            aria-hidden="true"
            class="intro-brand-mark shrink-0 text-indigo-600"
            fill="currentColor"
          >
            <path d="M769.28 714.24H234.24c-17.92 0-35.84-2.56-53.76-8.96-81.92-24.32-139.52-102.4-139.52-188.16C40.96 409.6 128 321.28 236.8 320 258.56 202.24 362.24 111.36 486.4 111.36c104.96 0 197.12 64 235.52 158.72 12.8-2.56 24.32-2.56 37.12-2.56 122.88 0 224 99.84 224 222.72 0 98.56-62.72 184.32-156.16 213.76-16.64 6.4-37.12 10.24-57.6 10.24zM238.08 395.52c-66.56 0-121.6 53.76-121.6 121.6 0 52.48 35.84 101.12 85.76 115.2 10.24 3.84 20.48 5.12 30.72 5.12H768c11.52 0 21.76-2.56 33.28-6.4 64-20.48 104.96-76.8 104.96-140.8 0-80.64-66.56-147.2-147.2-147.2-16.64 0-33.28 2.56-49.92 8.96l-39.68 14.08-10.24-40.96c-19.2-80.64-90.88-138.24-174.08-138.24-96 0-176.64 78.08-177.92 175.36v46.08l-44.8-8.96c-7.68-2.56-16.64-3.84-24.32-3.84zM263.68 912.64c-6.4 0-12.8-1.28-19.2-5.12-17.92-10.24-24.32-33.28-14.08-51.2l42.24-72.96c10.24-17.92 33.28-24.32 51.2-14.08 17.92 10.24 24.32 33.28 14.08 51.2l-42.24 72.96c-6.4 12.8-19.2 19.2-32 19.2zM464.64 912.64c-6.4 0-12.8-1.28-19.2-5.12-17.92-10.24-24.32-33.28-14.08-52.48l42.24-72.96c10.24-17.92 33.28-24.32 52.48-14.08 17.92 10.24 24.32 33.28 14.08 52.48l-42.24 72.96c-7.68 12.8-20.48 19.2-33.28 19.2zM666.88 912.64c-6.4 0-12.8-1.28-19.2-5.12-17.92-10.24-24.32-33.28-14.08-51.2l42.24-72.96c10.24-17.92 33.28-24.32 51.2-14.08 17.92 10.24 24.32 33.28 14.08 51.2l-42.24 72.96c-6.4 12.8-19.2 19.2-32 19.2z" />
          </svg>
          <span class="intro-brand-wordmark">RainerSeventeen</span>
        </span>
      </p>
      <p>
        这里是主站首页，选择一个感兴趣的分站入口以获取详细信息。
      </p>
    </div>

    <!-- <div class="flex justify-between items-center my-14">
      <div class="w-full sm:w-1/2 px-8 py-8 sm:py-0">
        <Image src={mindMapImage} alt="mind map" />
      </div>
      <div class="w-1/2 px-8 hidden sm:flex justify-end">
        <Image src={codeReviewImage} alt="code review" />
      </div>
    </div> -->
  </section>

  <!-- Destinations -->
  <section
    id="destinations"
    class="scroll-mt-16 mx-auto w-full max-w-4xl border-b border-gray-300 dark:border-gray-700 py-16 mb-16 relative px-4 xl:px-0"
  >
    <div class="max-w-2xl">
      <h3 class="home-heading-2 font-bold text-balance dark:text-gray-100">前往分站</h3>
      <p class="mt-3 text-gray-600 dark:text-gray-300">
        每个分站负责一个主题，选择一个分站查看。
      </p>
    </div>

    <div class="absolute right-0 transform rotate-180 translate-x-[120%]">
      <Image src={dotsTriangle} alt="dots" class="hidden xl:block" />
    </div>

    <ul class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-3">
      {
        destinations.map((dest) => (
          <li class="h-full">
            <a
              href={dest.href}
              target={dest.external ? '_blank' : undefined}
              rel={dest.external ? 'noopener noreferrer' : undefined}
              class="group flex h-full cursor-pointer flex-col rounded-lg border border-gray-300 bg-white p-4 text-inherit shadow-sm transition-all duration-300 hover:border-indigo-500 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 dark:border-gray-700 dark:bg-slate-900/80 dark:hover:border-indigo-400 dark:hover:shadow-[0_8px_20px_rgba(15,23,42,0.35)] dark:focus-visible:ring-offset-slate-950"
            >
              <div
                class:list={[
                  'flex aspect-[4/3] items-center justify-center overflow-hidden rounded-lg border border-gray-200 bg-gray-50 dark:border-slate-700 dark:bg-slate-950/70',
                  dest.label === 'Lab' ? 'p-5 sm:p-6' : 'p-2 sm:p-3',
                ]}
              >
                <Image
                  src={dest.artwork}
                  alt={dest.artworkAlt}
                  class:list={[
                    'h-full w-full object-contain',
                    dest.label === 'Lab' ? 'max-h-[220px]' : 'max-h-[300px]',
                  ]}
                />
              </div>

              <div class="flex flex-1 items-end justify-between gap-4 pt-4">
                <h4 class="text-xl font-semibold text-gray-950 transition-colors duration-200 group-hover:text-indigo-700 dark:text-gray-100 dark:group-hover:text-indigo-300">
                  {dest.label}
                </h4>

                <span class="home-arrow-link inline-flex shrink-0 items-center gap-2 text-sm font-semibold text-indigo-600 transition-colors duration-200 group-hover:text-indigo-700 dark:text-indigo-400 dark:group-hover:text-indigo-300">
                  {dest.ctaLabel}
                  <span
                    aria-hidden="true"
                    class="home-arrow-link-icon"
                  >
                    →
                  </span>
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Recent Notes -->
  <section class="mx-auto w-full max-w-4xl px-4 xl:px-0 py-4 mb-16">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h3 class="home-heading-2 font-bold text-balance dark:text-gray-100">最近更新</h3>
        <p class="mt-3 max-w-2xl text-gray-600 dark:text-gray-300">
          从 Note 站自动读取最近整理的内容，作为首页上的最新入口。
        </p>
      </div>
      <a
        href="https://note.rainerseventeen.com"
        target="_blank"
        rel="noopener noreferrer"
        class="home-arrow-link inline-flex items-center gap-2 text-indigo-600 dark:text-indigo-400 font-semibold transition-colors hover:text-indigo-700 dark:hover:text-indigo-300"
      >
        查看全部笔记
        <span aria-hidden="true" class="home-arrow-link-icon">→</span>
      </a>
    </div>

    {
      recentNotes.length > 0 ? (
        <ol class="mt-10 border-t border-gray-200 dark:border-gray-800">
          {
            recentNotes.map((note, index) => (
              <li class="border-b border-gray-200 dark:border-gray-800">
                <a
                  href={note.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group grid cursor-pointer gap-4 rounded-2xl px-2 py-5 transition-colors duration-200 hover:bg-gray-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 dark:hover:bg-slate-800/70 dark:focus-visible:ring-offset-slate-950 sm:grid-cols-[4.5rem_minmax(0,1fr)_auto] sm:items-center"
                >
                  <div class="flex items-center justify-center self-stretch sm:self-auto">
                    <span class="text-base font-semibold tracking-[0.18em] text-gray-400 dark:text-gray-500 sm:text-lg">
                      {(index + 1).toString().padStart(2, '0')}
                    </span>
                  </div>

                  <div class="min-w-0">
                    <h4 class="text-lg font-semibold text-gray-900 transition-colors duration-200 group-hover:text-indigo-700 dark:text-gray-100 dark:group-hover:text-indigo-300 sm:text-xl">
                      {note.title}
                    </h4>
                    <p class="mt-2 line-clamp-2 text-sm leading-7 text-gray-600 dark:text-gray-300 sm:text-base">
                      {note.description || '最近整理的一篇笔记，点击可直接跳转到 Note 站继续阅读。'}
                    </p>
                  </div>

                  <div class="flex items-center justify-between gap-4 text-sm text-gray-500 dark:text-gray-400 sm:flex-col sm:items-end sm:justify-start sm:text-right">
                    <time datetime={note.pubDate}>{formatDate(note.pubDate)}</time>
                    <span class="home-arrow-link inline-flex items-center gap-2 font-semibold text-indigo-600 transition-colors duration-200 group-hover:text-indigo-700 dark:text-indigo-400 dark:group-hover:text-indigo-300">
                      阅读笔记
                      <span
                        aria-hidden="true"
                        class="home-arrow-link-icon"
                      >
                        →
                      </span>
                    </span>
                  </div>
                </a>
              </li>
            ))
          }
        </ol>
      ) : (
        <div class="mt-10 rounded-2xl border border-dashed border-gray-300 bg-gray-50 px-6 py-8 text-sm text-gray-600 dark:border-gray-700 dark:bg-slate-900/60 dark:text-gray-300">
          目前还没有可展示的最近笔记。
        </div>
      )
    }
  </section>

  <!-- Featured Projects -->
  <section class="mx-auto w-full max-w-4xl px-4 xl:px-0 py-4 mb-16 relative">
    <div class="absolute right-0 top-0 translate-x-[120%]">
      <Image src={dotsTriangle} alt="dots" class="hidden xl:block" />
    </div>

    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h3 class="home-heading-2 font-bold text-balance dark:text-gray-100">项目展示</h3>
        <p class="mt-3 max-w-2xl text-gray-600 dark:text-gray-300">
          一些想法的具体实现，通过 GitHub 开源。
        </p>
      </div>
      <a
        href="https://github.com/RainerSeventeen"
        target="_blank"
        rel="noopener noreferrer"
        class="home-arrow-link inline-flex items-center gap-2 text-indigo-600 dark:text-indigo-400 font-semibold transition-colors hover:text-indigo-700 dark:hover:text-indigo-300"
      >
        GitHub 主页
        <span aria-hidden="true" class="home-arrow-link-icon">→</span>
      </a>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2">
      {
        repos.map((repo) => (
          <a
            href={repo.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex h-full cursor-pointer flex-col rounded-lg border border-gray-300 bg-white p-4 text-inherit shadow-sm transition-all duration-300 hover:border-indigo-500 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 dark:border-gray-700 dark:bg-slate-900/80 dark:hover:border-indigo-400 dark:hover:shadow-[0_8px_20px_rgba(15,23,42,0.35)]"
          >
            <div class="flex items-start justify-between gap-3">
              <div class="flex min-w-0 flex-1 items-center">
                <div class="flex min-w-0 items-center gap-2">
                  <img
                    src={getGitHubAvatar(repo.owner)}
                    alt={`${repo.owner} avatar`}
                    loading="lazy"
                    class="h-6 w-6 rounded-full border border-gray-200 bg-gray-100 object-cover dark:border-gray-700 dark:bg-slate-800"
                  />
                  <span class="truncate text-sm font-semibold text-gray-900 dark:text-gray-100">
                    {repo.owner}
                  </span>
                </div>
                <span class="mx-1.5 text-sm text-gray-400 dark:text-gray-500">/</span>
                <span class="truncate text-sm font-semibold text-indigo-600 transition-colors duration-200 group-hover:text-indigo-700 dark:text-indigo-400 dark:group-hover:text-indigo-300">
                  {repo.name}
                </span>
              </div>

              <div class="shrink-0 text-slate-950 transition-colors duration-200 dark:text-gray-300">
                <svg
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  class="h-6 w-6"
                  fill="currentColor"
                >
                  <path d="M12 .3C5.37.3 0 5.67 0 12.3c0 5.3 3.44 9.8 8.2 11.38.6.12.82-.26.82-.57v-2.02c-3.34.73-4.04-1.42-4.04-1.42-.54-1.38-1.33-1.75-1.33-1.75-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.92 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.17 0 0 1.01-.32 3.3 1.23a11.4 11.4 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.65.24 2.87.12 3.17.77.84 1.23 1.91 1.23 3.22 0 4.6-2.8 5.62-5.48 5.92.43.37.82 1.1.82 2.22v3.28c0 .32.22.69.82.57A12.02 12.02 0 0 0 24 12.3C24 5.67 18.63.3 12 .3Z"></path>
                </svg>
              </div>
            </div>

            <p class="mt-3 min-h-12 line-clamp-2 text-sm leading-6 text-gray-500 dark:text-gray-400">
              {repo.description}
            </p>

            <div class="mt-auto flex flex-wrap items-center gap-x-4 gap-y-2 pt-3 text-sm text-gray-500 dark:text-gray-400">
              <span class="inline-flex items-center">
                <svg
                  viewBox="0 0 16 16"
                  aria-hidden="true"
                  class="mr-1 h-4 w-4"
                  fill="currentColor"
                >
                  <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"></path>
                </svg>
                {formatRepoCount(repo.stars)}
              </span>

              <span class="inline-flex items-center">
                <svg
                  viewBox="0 0 16 16"
                  aria-hidden="true"
                  class="mr-1 h-4 w-4"
                  fill="currentColor"
                >
                  <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"></path>
                </svg>
                {formatRepoCount(repo.forks)}
              </span>

              <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-slate-800 dark:text-gray-300 sm:ml-auto">
                {repo.license}
              </span>
              <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-slate-800 dark:text-gray-300">
                {repo.language}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- About -->
  <section class="mx-auto w-full max-w-4xl relative px-4 xl:px-0">
    <h3 class="home-heading-2 font-bold text-balance dark:text-gray-100">关于作者</h3>

    <div class="flex items-center flex-col sm:flex-row mt-6">
      <img
        src={profile.avatar}
        alt={`${profile.name} 的头像`}
        width="128"
        height="128"
        loading="lazy"
        class="rounded-full w-32 h-32 object-cover"
      />
      <div>
        <p class="dark:text-gray-100 sm:ml-6 mt-6 sm:mt-0">
          {aboutPage.teaser}
        </p>
        <p class="text-gray-600 dark:text-gray-300 sm:ml-6 mt-4">
          {aboutPage.summary[0]}
        </p>
        <a
          href="/about"
          class="home-arrow-link inline-flex items-center gap-2 sm:ml-6 mt-6 rounded-full border border-indigo-200 bg-indigo-50 px-5 py-2.5 font-semibold text-indigo-700 transition-colors hover:border-indigo-300 hover:bg-indigo-100 dark:border-indigo-500/40 dark:bg-indigo-500/10 dark:text-indigo-300 dark:hover:bg-indigo-500/20"
        >
          查看完整 About
          <span aria-hidden="true" class="home-arrow-link-icon">→</span>
        </a>
      </div>
    </div>

    <div class="my-16"></div>
  </section>

  <!-- Contact -->
  <section
    id="contact"
    class="scroll-mt-28 mt-10 px-4 py-14 xl:px-0"
  >
    <div class="mx-auto w-full max-w-4xl relative">
      <h3 class="home-heading-2 font-bold text-balance dark:text-gray-100">联系作者</h3>

      <div class="absolute left-0 transform -translate-x-[120%] rotate-180">
        <Image src={dotsTriangle} alt="dots" class="hidden xl:block" />
      </div>

      <!-- <p class="mt-5 max-w-2xl text-gray-600 dark:text-gray-300">
        有任何想法、问题或合作意向，可以邮件联系我。
      </p> -->

      <div class="mt-7">
        <div class="group relative overflow-hidden rounded-lg border border-gray-300 bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-indigo-500 hover:shadow-md focus-within:border-indigo-500 dark:border-gray-700 dark:bg-slate-900/80 dark:hover:border-indigo-400 dark:hover:shadow-[0_8px_20px_rgba(15,23,42,0.35)] dark:focus-within:border-indigo-400 sm:p-6">
          <div class="relative flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex min-w-0 items-center gap-3">
              <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-gray-200 bg-gray-50 text-slate-950 transition-colors duration-200 group-hover:border-indigo-200 group-hover:bg-indigo-50 group-hover:text-indigo-600 dark:border-slate-700 dark:bg-slate-800 dark:text-gray-200 dark:group-hover:border-indigo-400/40 dark:group-hover:bg-indigo-500/10 dark:group-hover:text-indigo-300">
                <Fragment set:html={contactEmailIcon} />
              </span>
              <div class="min-w-0">
                <span class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-slate-800 dark:text-gray-300">
                  Email
                </span>
                <h4 class="mt-2 min-w-0 text-base font-semibold leading-snug text-gray-950 dark:text-gray-100 sm:text-lg">
                  <span class="break-all">{contactEmailLocal}</span><span class="text-gray-300 dark:text-slate-600">@</span><span class="break-all">{contactEmailDomain}</span>
                </h4>
              </div>
            </div>

            <div class="flex shrink-0 flex-col gap-2.5 sm:flex-row">
              <a
                href={emailLink?.href ?? '#'}
                class="home-arrow-link inline-flex cursor-pointer items-center justify-center gap-2 rounded-xl bg-gray-950 px-4 py-2.5 text-sm font-semibold text-white transition-colors duration-200 hover:bg-gray-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 dark:bg-white dark:text-slate-950 dark:hover:bg-gray-200 dark:focus-visible:ring-offset-slate-900"
              >
                写邮件
                <span aria-hidden="true" class="home-arrow-link-icon">↗</span>
              </a>
              <button
                id="copy-contact-email"
                type="button"
                data-email={contactEmail}
                class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 transition-colors duration-200 hover:border-gray-300 hover:bg-gray-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 dark:border-slate-700 dark:bg-slate-900 dark:text-gray-200 dark:hover:border-slate-600 dark:hover:bg-slate-800 dark:focus-visible:ring-offset-slate-900"
                aria-describedby="copy-contact-email-status"
              >
                <span id="copy-contact-email-label">复制邮箱</span>
              </button>
              <span
                id="copy-contact-email-status"
                class="sr-only"
                aria-live="polite"
              ></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
  const copyEmailButton = document.querySelector('#copy-contact-email')
  const copyEmailLabel = document.querySelector('#copy-contact-email-label')
  const copyEmailStatus = document.querySelector('#copy-contact-email-status')

  if (copyEmailButton instanceof HTMLButtonElement) {
    const defaultLabel = '复制邮箱'

    copyEmailButton.addEventListener('click', async () => {
      const email = copyEmailButton.dataset.email
      if (!email) return

      let copied = false

      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(email)
          copied = true
        } else {
          const textarea = document.createElement('textarea')
          textarea.value = email
          textarea.setAttribute('readonly', '')
          textarea.style.position = 'absolute'
          textarea.style.left = '-9999px'
          document.body.appendChild(textarea)
          textarea.select()
          copied = document.execCommand('copy')
          document.body.removeChild(textarea)
        }
      } catch {
        copied = false
      }

      if (copyEmailLabel) {
        copyEmailLabel.textContent = copied ? '已复制' : '复制失败'
      }

      if (copyEmailStatus) {
        copyEmailStatus.textContent = copied ? '邮箱已复制到剪贴板' : '复制邮箱失败'
      }

      window.setTimeout(() => {
        if (copyEmailLabel) {
          copyEmailLabel.textContent = defaultLabel
        }

        if (copyEmailStatus) {
          copyEmailStatus.textContent = ''
        }
      }, 1800)
    })
  }
</script>

