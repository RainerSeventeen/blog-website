---
const pathname = Astro.url.pathname

const navigation = [
  { href: '/', title: '首页', icon: 'home', newTab: false },
  { href: '/about', title: '关于', icon: 'about', newTab: false },
]
---

<header
  class="fixed bg-white dark:bg-slate-900 dark:text-gray-100 top-0 left-0 w-full z-40 border-t-[14px] border-indigo-600"
>
  <nav
    class="mx-auto flex w-full max-w-6xl flex-wrap items-center justify-between px-5 py-6 xl:px-2"
  >
    <!-- Logo / Brand -->
    <div class="flex items-center">
      <a
        href="/"
        class="group inline-flex max-w-full items-center gap-3 overflow-hidden text-slate-900 transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-indigo-600 dark:text-white"
        aria-label="RainerSeventeen 首页"
      >
        <svg
          viewBox="0 0 1024 1024"
          aria-hidden="true"
          class="site-logo-mark shrink-0 text-indigo-600 drop-shadow-[0_10px_18px_rgba(61,80,245,0.28)] transition-transform duration-200 group-hover:-translate-y-0.5 group-focus-visible:-translate-y-0.5"
          fill="currentColor"
        >
          <path d="M769.28 714.24H234.24c-17.92 0-35.84-2.56-53.76-8.96-81.92-24.32-139.52-102.4-139.52-188.16C40.96 409.6 128 321.28 236.8 320 258.56 202.24 362.24 111.36 486.4 111.36c104.96 0 197.12 64 235.52 158.72 12.8-2.56 24.32-2.56 37.12-2.56 122.88 0 224 99.84 224 222.72 0 98.56-62.72 184.32-156.16 213.76-16.64 6.4-37.12 10.24-57.6 10.24zM238.08 395.52c-66.56 0-121.6 53.76-121.6 121.6 0 52.48 35.84 101.12 85.76 115.2 10.24 3.84 20.48 5.12 30.72 5.12H768c11.52 0 21.76-2.56 33.28-6.4 64-20.48 104.96-76.8 104.96-140.8 0-80.64-66.56-147.2-147.2-147.2-16.64 0-33.28 2.56-49.92 8.96l-39.68 14.08-10.24-40.96c-19.2-80.64-90.88-138.24-174.08-138.24-96 0-176.64 78.08-177.92 175.36v46.08l-44.8-8.96c-7.68-2.56-16.64-3.84-24.32-3.84zM263.68 912.64c-6.4 0-12.8-1.28-19.2-5.12-17.92-10.24-24.32-33.28-14.08-51.2l42.24-72.96c10.24-17.92 33.28-24.32 51.2-14.08 17.92 10.24 24.32 33.28 14.08 51.2l-42.24 72.96c-6.4 12.8-19.2 19.2-32 19.2zM464.64 912.64c-6.4 0-12.8-1.28-19.2-5.12-17.92-10.24-24.32-33.28-14.08-52.48l42.24-72.96c10.24-17.92 33.28-24.32 52.48-14.08 17.92 10.24 24.32 33.28 14.08 52.48l-42.24 72.96c-7.68 12.8-20.48 19.2-33.28 19.2zM666.88 912.64c-6.4 0-12.8-1.28-19.2-5.12-17.92-10.24-24.32-33.28-14.08-51.2l42.24-72.96c10.24-17.92 33.28-24.32 51.2-14.08 17.92 10.24 24.32 33.28 14.08 51.2l-42.24 72.96c-6.4 12.8-19.2 19.2-32 19.2z" />
        </svg>
        <span class="site-wordmark truncate transition-transform duration-200 group-hover:-translate-y-0.5 group-focus-visible:-translate-y-0.5">
          RainerSeventeen
        </span>
      </a>
    </div>

    <!-- Mobile quick actions -->
    <div class="flex items-center gap-2 lg:hidden">
      {
        navigation.map((nav) => {
          const isActive = pathname === nav.href
          return (
            <a
              href={nav.href}
              target={nav.newTab ? '_blank' : undefined}
              rel={nav.newTab ? 'noopener noreferrer' : undefined}
              aria-label={nav.title}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'nav-icon-button nav-mobile-action',
                isActive && 'is-active',
              ]}
            >
              {nav.icon === 'home' ? (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.7"
                  stroke="currentColor"
                  aria-hidden="true"
                  class="h-5 w-5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m2.25 12 8.954-8.955a1.125 1.125 0 0 1 1.592 0L21.75 12M4.5 9.75V19.5A1.5 1.5 0 0 0 6 21h3.75v-5.25c0-.414.336-.75.75-.75h3c.414 0 .75.336.75.75V21H18a1.5 1.5 0 0 0 1.5-1.5V9.75"
                  ></path>
                </svg>
              ) : (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.7"
                  stroke="currentColor"
                  aria-hidden="true"
                  class="h-5 w-5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15.75 6.75a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.118a7.5 7.5 0 0 1 15 0A17.933 17.933 0 0 1 12 21.75a17.933 17.933 0 0 1-7.5-1.632Z"
                  ></path>
                </svg>
              )}
              <span class="sr-only">{nav.title}</span>
            </a>
          )
        })
      }

      <button
        type="button"
        class="nav-icon-button nav-mobile-action"
        data-theme-toggle
        aria-label="切换主题"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
          class="hidden h-5 w-5 dark:block"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
          ></path>
        </svg>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
          class="block h-5 w-5 dark:hidden"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Desktop nav -->
    <ul
      class="hidden items-center gap-2 lg:flex"
    >
      <li>
        <button
          type="button"
          class="nav-icon-button"
          data-theme-toggle
          aria-label="切换主题"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            aria-hidden="true"
            class="hidden w-6 h-6 dark:block"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
            ></path>
          </svg>
          <svg
            id="moonIcon"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            aria-hidden="true"
            class="block w-6 h-6 dark:hidden"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
            ></path>
          </svg>
        </button>
      </li>

      {
        navigation.map((nav) => (
          <li>
            <a
              href={nav.href}
              target={nav.newTab ? '_blank' : undefined}
              rel={nav.newTab ? 'noopener noreferrer' : undefined}
              aria-current={pathname === nav.href ? 'page' : undefined}
              class:list={[
                'nav-link',
                pathname === nav.href && 'is-active',
              ]}
            >
              {nav.title}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  function initNavThemeControls() {
    const themeToggles = document.querySelectorAll('[data-theme-toggle]')
    if (themeToggles.length === 0) return

    themeToggles.forEach((themeToggle) => {
      if (!(themeToggle instanceof HTMLButtonElement)) return
      if (themeToggle.dataset.bound === 'true') return

      themeToggle.dataset.bound = 'true'
      themeToggle.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark')
        const isDark = document.documentElement.classList.contains('dark')
        localStorage.setItem('theme', isDark ? 'dark' : 'light')
      })
    })
  }

  initNavThemeControls()
  document.addEventListener('astro:page-load', initNavThemeControls)
</script>

<style>
  .site-wordmark,
  .nav-link {
    font-family: var(--font-sans);
    font-weight: 800;
    letter-spacing: -0.035em;
  }

  .site-logo-mark {
    width: clamp(2rem, 1.6rem + 0.9vw, 2.45rem);
    height: clamp(2rem, 1.6rem + 0.9vw, 2.45rem);
  }

  .site-wordmark {
    font-size: clamp(1rem, 0.92rem + 0.34vw, 1.16rem);
    line-height: 1;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.55rem 0.9rem;
    font-size: 0.96rem;
    line-height: 1;
    text-transform: none;
    color: rgb(15 23 42);
    transition:
      color 180ms ease,
      opacity 180ms ease;
  }

  .nav-link:hover {
    color: rgb(79 70 229);
    opacity: 0.88;
  }

  .nav-link.is-active {
    color: rgb(79 70 229);
  }

  .nav-link:focus-visible {
    color: rgb(79 70 229);
    outline: 2px solid rgb(79 70 229 / 0.45);
    outline-offset: 4px;
    border-radius: 0.35rem;
  }

  .nav-icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: rgb(15 23 42);
    cursor: pointer;
    transition:
      color 180ms ease,
      opacity 180ms ease;
  }

  .nav-icon-button:hover {
    color: rgb(79 70 229);
    opacity: 0.88;
  }

  .nav-mobile-action {
    border: 1px solid rgb(226 232 240 / 0.95);
    border-radius: 9999px;
    background: rgb(255 255 255 / 0.82);
    box-shadow: 0 10px 28px rgb(15 23 42 / 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-mobile-action.is-active {
    color: rgb(79 70 229);
    background: rgb(238 242 255 / 0.98);
    border-color: rgb(165 180 252 / 0.95);
  }

  .nav-icon-button:focus-visible {
    color: rgb(79 70 229);
    outline: 2px solid rgb(79 70 229 / 0.45);
    outline-offset: 4px;
    border-radius: 9999px;
  }

  :global(.dark) .nav-link,
  :global(.dark) .nav-icon-button {
    color: rgb(248 250 252);
  }

  :global(.dark) .nav-link:hover,
  :global(.dark) .nav-link:focus-visible,
  :global(.dark) .nav-icon-button:hover,
  :global(.dark) .nav-icon-button:focus-visible {
    color: rgb(199 210 254);
  }

  :global(.dark) .nav-link.is-active,
  :global(.dark) .nav-mobile-action.is-active {
    color: rgb(199 210 254);
  }

  :global(.dark) .nav-mobile-action {
    border-color: rgb(51 65 85 / 0.95);
    background: rgb(15 23 42 / 0.78);
    box-shadow: 0 14px 30px rgb(2 6 23 / 0.38);
  }

  :global(.dark) .nav-mobile-action.is-active {
    background: rgb(49 46 129 / 0.35);
    border-color: rgb(129 140 248 / 0.65);
  }

  :global(.dark) .nav-link:focus-visible,
  :global(.dark) .nav-icon-button:focus-visible {
    outline-color: rgb(129 140 248 / 0.45);
  }

  @media (max-width: 1023px) {
    .nav-icon-button {
      width: 2.6rem;
      height: 2.6rem;
    }
  }
</style>
